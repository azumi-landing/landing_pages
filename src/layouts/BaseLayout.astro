---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import SectionNav from '../components/SectionNav.astro';
---
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>hg</title>
    <meta name="description" content="Software personalizado para operaciones de campo. +10 años de experiencia, +5M registros procesados. Soluciones que funcionan offline y se adoptan rápido." />
    
    <!-- Open Graph / WhatsApp / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://hguerra.com" />
    <meta property="og:title" content="HGuerra | Especialista en Software para Operaciones de Campo" />
    <meta property="og:description" content="Software personalizado para operaciones de campo. +10 años de experiencia, +5M registros procesados. Soluciones que funcionan offline y se adoptan rápido." />
    <meta property="og:image" content="https://hguerra.com/mi_foto_pro.jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_ES" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://hguerra.com" />
    <meta property="twitter:title" content="HGuerra | Especialista en Software para Operaciones de Campo" />
    <meta property="twitter:description" content="Software personalizado para operaciones de campo. +10 años de experiencia, +5M registros procesados." />
    <meta property="twitter:image" content="https://hguerra.com/mi_foto_pro.jpeg" />
    
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="icon" type="image/svg+xml" href="/hg-favicon.svg">
  </head>
  <body>
    <Navbar />
    <SectionNav />
    <slot />
  </body>
</html>
