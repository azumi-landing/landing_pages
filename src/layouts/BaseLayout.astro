---
import '../styles/global.css';
import MainNav from '../components/MainNav.astro';
import SectionNav from '../components/SectionNav.astro';
import WhatsAppFloatingButton from '../components/atoms/WhatsAppFloatingButton.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SeoHead from '../components/SeoHead.astro';
import { siteConfig } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  schemas?: Array<Record<string, unknown>>;
}

const {
  title = 'HGuerra | Especialista en Software para Operaciones de Campo',
  description = 'Software personalizado para operaciones de campo. +10 años de experiencia, +5M registros procesados. Soluciones que funcionan offline y se adoptan rápido.',
  path = '/gestion-de-operaciones-de-campo',
  image = siteConfig.defaultImage,
  type = 'website',
  noindex = false,
  schemas = []
} = Astro.props;
---
<html lang="es">
  <head>
    <SeoHead
      title={title}
      description={description}
      path={path}
      image={image}
      type={type}
      noindex={noindex}
      schemas={schemas}
    />
  </head>
  <body>
    <MainNav currentPath={path} />
    <SectionNav />
    <slot />
    <SiteFooter />
    <WhatsAppFloatingButton />
  </body>
</html>
