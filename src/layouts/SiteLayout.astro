---
import '../styles/global.css';
import MainNav from '../components/MainNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import WhatsAppFloatingButton from '../components/atoms/WhatsAppFloatingButton.astro';
import SeoHead from '../components/SeoHead.astro';
import { siteConfig } from '../data/site';

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  schemas?: Array<Record<string, unknown>>;
}

const {
  title,
  description,
  path = '/',
  image = siteConfig.defaultImage,
  type = 'website',
  noindex = false,
  schemas = []
} = Astro.props;
---
<html lang="es">
  <head>
    <SeoHead
      title={title}
      description={description}
      path={path}
      image={image}
      type={type}
      noindex={noindex}
      schemas={schemas}
    />
  </head>
  <body class="bg-slate-950 text-white">
    <MainNav currentPath={path} />
    <slot />
    <SiteFooter />
    <WhatsAppFloatingButton />
  </body>
</html>
