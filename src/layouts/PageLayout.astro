---
import '../styles/global.css';
import MainNav from '../components/MainNav.astro';
import SectionNav from '../components/SectionNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import WhatsAppFloatingButton from '../components/atoms/WhatsAppFloatingButton.astro';
import SeoHead from '../components/SeoHead.astro';
import { siteConfig } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  schemas?: Array<Record<string, unknown>>;
  bodyVariant?: 'dark' | 'light' | 'mixed';
  showSectionNav?: boolean;
  sectionNavItems?: Array<{ id: string; label: string }>;
}

const {
  title = siteConfig.name,
  description = siteConfig.description,
  path = '/',
  image = siteConfig.defaultImage,
  type = 'website',
  noindex = false,
  schemas = [],
  bodyVariant = 'mixed',
  showSectionNav = false,
  sectionNavItems = []
} = Astro.props;

const bodyClass = {
  dark: 'page-body-dark',
  light: 'page-body-light',
  mixed: 'page-body-mixed'
}[bodyVariant];
---
<html lang="es">
  <head>
    <SeoHead
      title={title}
      description={description}
      path={path}
      image={image}
      type={type}
      noindex={noindex}
      schemas={schemas}
    />
  </head>
  <body class={bodyClass}>
    <MainNav currentPath={path} />
    {showSectionNav && sectionNavItems.length > 0 && <SectionNav items={sectionNavItems} />}
    <slot />
    <SiteFooter />
    <WhatsAppFloatingButton />
  </body>
</html>
