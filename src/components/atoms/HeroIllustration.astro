---
// SVG animado representando operaciones de campo conectadas a la nube
// hguerra.com branding incluido
---

<svg viewBox="0 0 400 400" class="w-full max-w-md h-auto overflow-visible" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <!-- Gradients -->
    <linearGradient id="phoneGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3B82F6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1E40AF;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="screenGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1E293B;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0F172A;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="cloudGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#60A5FA;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#3B82F6;stop-opacity:0.6" />
    </linearGradient>
    <linearGradient id="dashGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#10B981;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#059669;stop-opacity:1" />
    </linearGradient>
    
    <!-- Glow filter -->
    <filter id="glow">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    
    <!-- Pulse animation -->
    <style>
      @keyframes pulse {
        0%, 100% { opacity: 0.4; }
        50% { opacity: 1; }
      }
      @keyframes flow {
        0% { stroke-dashoffset: 100; }
        100% { stroke-dashoffset: 0; }
      }
      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
      }
      @keyframes rotate {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
      }
      @keyframes dataPacket {
        0% { offset-distance: 0%; opacity: 0; }
        10% { opacity: 1; }
        90% { opacity: 1; }
        100% { offset-distance: 100%; opacity: 0; }
      }
      @keyframes signal {
        0% { r: 0; opacity: 1; }
        100% { r: 30; opacity: 0; }
      }
      
      .pulse-dot { animation: pulse 2s ease-in-out infinite; }
      .pulse-dot-2 { animation: pulse 2s ease-in-out infinite 0.5s; }
      .pulse-dot-3 { animation: pulse 2s ease-in-out infinite 1s; }
      .flow-line { 
        stroke-dasharray: 10, 5;
        animation: flow 2s linear infinite;
      }
      .float-element { animation: float 3s ease-in-out infinite; }
      .cloud-float { animation: float 4s ease-in-out infinite; }
      .data-packet {
        offset-path: path('M60,320 Q200,250 200,180 Q200,110 340,100');
        animation: dataPacket 3s ease-in-out infinite;
      }
      .data-packet-reverse {
        offset-path: path('M340,130 Q200,140 200,210 Q200,280 60,290');
        animation: dataPacket 3s ease-in-out infinite 1.5s;
      }
      .signal-ring {
        animation: signal 2s ease-out infinite;
      }
      .signal-ring-2 {
        animation: signal 2s ease-out infinite 0.6s;
      }
      
      /* Branding text style */
      .brand-text {
        font-family: 'Montserrat', sans-serif;
        font-weight: 700;
        font-size: 10px;
        letter-spacing: 2px;
      }
    </style>
  </defs>
  
  <!-- Connection path (background) -->
  <path d="M60,320 Q200,250 200,180 Q200,110 340,100" 
        fill="none" stroke="#3B82F6" stroke-width="2" stroke-opacity="0.3"/>
  <path d="M60,320 Q200,250 200,180 Q200,110 340,100" 
        fill="none" stroke="#60A5FA" stroke-width="2" class="flow-line"/>
  
  <!-- Return path -->
  <path d="M340,130 Q200,140 200,210 Q200,280 60,290" 
        fill="none" stroke="#10B981" stroke-width="2" stroke-opacity="0.3"/>
  <path d="M340,130 Q200,140 200,210 Q200,280 60,290" 
        fill="none" stroke="#34D399" stroke-width="2" class="flow-line" style="animation-delay: -1s"/>
  
  <!-- Data packets -->
  <circle r="4" fill="#60A5FA" class="data-packet"/>
  <circle r="4" fill="#34D399" class="data-packet-reverse"/>
  
  <!-- Cloud (Server/Dashboard) -->
  <g class="cloud-float" transform="translate(320, 80)">
    <ellipse cx="20" cy="35" rx="35" ry="20" fill="url(#cloudGrad)" filter="url(#glow)"/>
    <ellipse cx="0" cy="30" rx="20" ry="15" fill="url(#cloudGrad)" filter="url(#glow)"/>
    <ellipse cx="40" cy="30" rx="20" ry="15" fill="url(#cloudGrad)" filter="url(#glow)"/>
    <ellipse cx="20" cy="15" rx="25" ry="18" fill="url(#cloudGrad)" filter="url(#glow)"/>
    
    <!-- Dashboard icon inside cloud -->
    <rect x="5" y="25" width="30" height="20" rx="3" fill="#0F172A" stroke="#60A5FA" stroke-width="1"/>
    <rect x="8" y="28" width="8" height="3" rx="1" fill="#10B981"/>
    <rect x="18" y="28" width="8" height="3" rx="1" fill="#3B82F6"/>
    <rect x="8" y="33" width="6" height="3" rx="1" fill="#F59E0B"/>
    <rect x="16" y="33" width="10" height="3" rx="1" fill="#EF4444"/>
  </g>
  
  <!-- Signal waves from cloud -->
  <g transform="translate(340, 115)">
    <circle r="0" fill="none" stroke="#60A5FA" stroke-width="2" class="signal-ring"/>
    <circle r="0" fill="none" stroke="#60A5FA" stroke-width="2" class="signal-ring-2"/>
  </g>
  
  <!-- Phone Device -->
  <g class="float-element" transform="translate(20, 260)">
    <!-- Phone body -->
    <rect x="0" y="0" width="80" height="120" rx="12" fill="url(#phoneGrad)" stroke="#60A5FA" stroke-width="2" filter="url(#glow)"/>
    
    <!-- Screen -->
    <rect x="6" y="8" width="68" height="90" rx="6" fill="url(#screenGrad)"/>
    
    <!-- App interface -->
    <!-- Header -->
    <rect x="10" y="12" width="60" height="8" rx="2" fill="#3B82F6" opacity="0.8"/>
    <circle cx="16" cy="16" r="2" fill="#10B981" class="pulse-dot"/>
    
    <!-- Form fields -->
    <rect x="10" y="24" width="60" height="10" rx="2" fill="#1E293B" stroke="#3B82F6" stroke-width="0.5"/>
    <rect x="12" y="27" width="30" height="4" rx="1" fill="#64748B"/>
    
    <rect x="10" y="38" width="60" height="10" rx="2" fill="#1E293B" stroke="#3B82F6" stroke-width="0.5"/>
    <rect x="12" y="41" width="40" height="4" rx="1" fill="#64748B"/>
    
    <rect x="10" y="52" width="60" height="10" rx="2" fill="#1E293B" stroke="#3B82F6" stroke-width="0.5"/>
    <rect x="12" y="55" width="25" height="4" rx="1" fill="#64748B"/>
    
    <!-- Camera/GPS button -->
    <circle cx="40" cy="78" r="10" fill="#10B981" class="pulse-dot-2"/>
    <circle cx="40" cy="78" r="5" fill="#FFFFFF"/>
    
    <!-- GPS icon -->
    <path d="M40,75 L42,80 L38,80 Z" fill="#059669"/>
    
    <!-- Submit button -->
    <rect x="15" y="95" width="50" height="10" rx="5" fill="#3B82F6"/>
    <text x="40" y="102" text-anchor="middle" fill="white" font-size="6" font-weight="bold">ENVIAR</text>
    
    <!-- Home button -->
    <circle cx="40" cy="112" r="4" fill="#1E293B" stroke="#60A5FA" stroke-width="1"/>
    
    <!-- Offline indicator -->
    <rect x="55" y="12" width="15" height="5" rx="2" fill="#10B981"/>
    <text x="62" y="16" text-anchor="middle" fill="white" font-size="3">OFFLINE</text>
  </g>
  
  <!-- Signal waves from phone -->
  <g transform="translate(60, 290)">
    <circle r="0" fill="none" stroke="#3B82F6" stroke-width="2" class="signal-ring"/>
    <circle r="0" fill="none" stroke="#3B82F6" stroke-width="2" class="signal-ring-2"/>
  </g>
  
  <!-- Floating data points -->
  <circle cx="150" cy="200" r="3" fill="#60A5FA" class="pulse-dot"/>
  <circle cx="250" cy="150" r="3" fill="#34D399" class="pulse-dot-2"/>
  <circle cx="180" cy="280" r="3" fill="#F59E0B" class="pulse-dot-3"/>
  <circle cx="300" cy="220" r="3" fill="#EF4444" class="pulse-dot"/>
  
  <!-- Chart bars floating -->
  <g transform="translate(280, 200)" opacity="0.8">
    <rect x="0" y="15" width="6" height="15" rx="1" fill="#3B82F6" class="pulse-dot"/>
    <rect x="8" y="8" width="6" height="22" rx="1" fill="#10B981" class="pulse-dot-2"/>
    <rect x="16" y="20" width="6" height="10" rx="1" fill="#F59E0B" class="pulse-dot-3"/>
  </g>
  
  <!-- GPS Pin -->
  <g transform="translate(180, 180)">
    <ellipse cx="0" cy="0" rx="20" ry="10" fill="#3B82F6" opacity="0.3" class="pulse-dot"/>
    <path d="M0,-25 C-8,-25 -15,-18 -15,-10 C-15,0 0,15 0,15 C0,15 15,0 15,-10 C15,-18 8,-25 0,-25" fill="#EF4444" class="float-element"/>
    <circle cx="0" cy="-10" r="5" fill="white"/>
  </g>
  
  <!-- Logo/Branding -->
  <text x="200" y="380" text-anchor="middle" fill="#60A5FA" class="brand-text" style="opacity: 0.6;">hguerra.com</text>
  
  <!-- Connection nodes -->
  <circle cx="200" cy="180" r="6" fill="#3B82F6" filter="url(#glow)" class="pulse-dot"/>
  <circle cx="200" cy="180" r="3" fill="#FFFFFF"/>
</svg>
