---
interface Props {
  variant?: 'primary' | 'secondary' | 'accent' | 'neutral' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { 
  variant = 'primary', 
  size = 'md',
  class: className = ''
} = Astro.props;

const baseClasses = 'badge';

const variantClasses = {
  primary: 'badge-primary bg-[#1E3A8A]/20 text-[#1E3A8A] border-[#1E3A8A]/30',
  secondary: 'badge-secondary bg-[#3B82F6]/20 text-[#3B82F6] border-[#3B82F6]/30',
  accent: 'badge-accent bg-[#10B981]/20 text-[#10B981] border-[#10B981]/30',
  neutral: 'badge-neutral bg-[#64748B]/20 text-[#64748B] border-[#64748B]/30',
  outline: 'badge-outline border-[#CBD5E1] text-[#64748B]'
};

const sizeClasses = {
  sm: 'badge-sm text-xs',
  md: 'text-sm px-3 py-1',
  lg: 'badge-lg text-base px-4 py-2'
};

const classes = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className}`;
---

<span class={classes}>
  <slot />
</span>
