---
import { getWhatsAppHref } from '../../data/contact';

const whatsappHref = getWhatsAppHref();
---

<a
  href={whatsappHref}
  target="_blank"
  rel="noreferrer"
  aria-label="Escribir por WhatsApp"
  class="fixed right-5 bottom-5 z-40 inline-flex items-center gap-3 rounded-full bg-green-500 px-5 py-3 text-sm font-semibold text-slate-950 shadow-[0_20px_40px_rgba(34,197,94,0.35)] transition-all hover:-translate-y-0.5 hover:bg-green-400 md:right-8 md:bottom-8"
>
  <i class="fab fa-whatsapp text-xl"></i>
  <span class="hidden sm:inline">WhatsApp</span>
</a>
