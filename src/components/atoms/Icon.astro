---
import type { IconName } from '../../types';

interface Props {
  name: IconName;
  size?: 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '3xl';
  class?: string;
}

const { name, size = 'md', class: className = '' } = Astro.props;

const sizeClasses = {
  sm: 'text-sm',
  md: 'text-base',
  lg: 'text-lg',
  xl: 'text-3xl',
  '2xl': 'text-4xl',
  '3xl': 'text-5xl'
};
---

<i class={`fas ${name} ${sizeClasses[size]} ${className}`}></i>
