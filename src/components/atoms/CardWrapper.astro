---
interface Props {
  hover?: boolean;
  bordered?: boolean;
  dashed?: boolean;
  class?: string;
  onclick?: string;
  'data-sector'?: string;
}

const { 
  hover = true,
  bordered = true,
  dashed = false,
  class: className = '',
  onclick,
  'data-sector': dataSector
} = Astro.props;

const baseClasses = 'card bg-[#F8FAFC] p-8 rounded-2xl transition-all duration-300 flex flex-col items-center text-center';

const hoverClasses = hover ? 'hover:-translate-y-1 hover:shadow-xl hover:border-[#CBD5E1] cursor-pointer' : '';

const borderClasses = dashed 
  ? 'border-2 border-dashed border-[#CBD5E1] bg-[#FAFBFC] hover:bg-[#F8FAFC]' 
  : (bordered ? 'border border-[#E2E8F0]' : '');

const classes = `${baseClasses} ${hoverClasses} ${borderClasses} ${className}`;
---

<div 
  class={classes}
  onclick={onclick}
  data-sector={dataSector}
>
  <slot />
</div>
