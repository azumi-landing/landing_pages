---
import FlowLevel from '../molecules/FlowLevel.astro';
import Icon from '../atoms/Icon.astro';
import Contact from '../sections/Contact/index.astro';

import TrustBand from '../sections/TrustBand.astro';
import type { ServiceLandingConfig } from '../../types/serviceLanding';

interface Props {
  config: ServiceLandingConfig;
}

const { config } = Astro.props;
const themeVars = `--service-accent: ${config.theme.accent}; --service-accent-alt: ${config.theme.accentAlt}; --service-accent-soft: ${config.theme.accentSoft}; --service-accent-glow: ${config.theme.accentGlow}; --service-accent-shadow: ${config.theme.accentShadow};`;
const heroPatternClass = {
  grid: 'service-pattern-grid',
  mesh: 'service-pattern-mesh',
  flow: 'service-pattern-flow'
}[config.theme.pattern];
---

<main class="service-landing" style={themeVars}>
  <section id="inicio" class="service-hero section-shell-hero relative min-h-screen overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.15) 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
    <div class={`service-pattern absolute inset-0 opacity-40 ${heroPatternClass}`}></div>
    <div class="service-hero-glow service-hero-glow-primary absolute left-[-8rem] top-20 h-72 w-72 rounded-full blur-3xl"></div>
    <div class="service-hero-glow service-hero-glow-secondary absolute right-[-4rem] top-12 h-64 w-64 rounded-full blur-3xl"></div>

    <div class="page-container relative z-10 min-h-screen flex flex-col justify-center gap-12">
      <div class="max-w-4xl">
        <span class="service-hero-badge inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold rounded-full mb-6">
          <Icon name={config.theme.badgeIcon} size="sm" class="service-accent-text" />
          {config.badge}
        </span>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          {config.title}
        </h1>

        <p class="text-xl md:text-2xl text-slate-300 mb-8 leading-relaxed max-w-4xl">
          {config.subtitle}
        </p>

        <div class="service-context-chip inline-flex items-center gap-3 rounded-full px-4 py-2 mb-8 text-xs font-semibold uppercase tracking-[0.24em] text-white/80">
          <span class="service-context-dot h-2.5 w-2.5 rounded-full"></span>
          {config.theme.serviceLabel}
        </div>

        <div class="grid sm:grid-cols-3 gap-4 mb-10">
          {config.benefits.map((benefit) => (
            <div class="flex items-start gap-3">
              <span class="service-accent-text text-xl shrink-0">✓</span>
              <span class="text-slate-300">{benefit}</span>
            </div>
          ))}
        </div>

        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a
            href={config.primaryCtaHref}
            class="service-primary-cta px-8 py-4 text-white font-bold rounded-xl text-lg text-center transition-all duration-300 border"
          >
            {config.primaryCtaLabel} →
          </a>
          <a
            href={config.secondaryCtaHref}
            class="px-8 py-4 bg-white/10 hover:bg-white/20 text-white font-bold rounded-xl text-lg text-center transition-all duration-300 border border-white/20"
          >
            {config.secondaryCtaLabel}
          </a>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {config.metrics.map((metric) => (
            <div class="service-metric-card surface-card-dark p-6">
              <p class="service-accent-text text-2xl font-bold mb-2">{metric.value}</p>
              <p class="text-sm text-slate-300">{metric.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {config.trustBand.items.length > 0 && (
    <TrustBand
      eyebrow={config.trustBand.eyebrow}
      title={config.trustBand.title}
      description={config.trustBand.description}
      items={config.trustBand.items}
      tone="muted"
    />
  )}

  <section id="problema" class="section-shell section-light">
    <div class="page-container-wide">
      <div class="section-intro section-intro-center max-w-3xl mx-auto mb-12">
        <h2 class="section-title text-[#1E293B] text-3xl md:text-4xl font-bold mb-5">
          {config.problemTitle}
        </h2>
        <p class="section-copy text-[#475569] text-lg leading-relaxed">
          {config.problemSubtitle}
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 mb-12">
        {config.problemCards.map((card) => (
          <div class="surface-card p-6 hover:shadow-md transition-all duration-200 border border-slate-100">
            <div class="w-11 h-11 rounded-lg bg-red-50 flex items-center justify-center mb-4">
              <Icon name={card.icon} size="md" class="text-red-500" />
            </div>
            <h3 class="text-base font-bold text-[#1E293B] mb-2 leading-snug">{card.title}</h3>
            <p class="text-[#475569] text-sm leading-relaxed">{card.description}</p>
          </div>
        ))}
      </div>

      {config.riskTitle && (
        <div class="bg-gradient-to-r from-red-50 to-orange-50 border border-red-200 rounded-2xl p-8">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-red-500 flex items-center justify-center shrink-0">
              <Icon name="fa-exclamation" size="lg" class="text-white" />
            </div>
            <div>
              <h3 class="text-xl font-bold text-[#1E293B] mb-2">{config.riskTitle}</h3>
              <p class="text-[#475569] leading-relaxed">{config.riskDescription}</p>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>

  {config.consequences && config.consequences.length > 0 && (
    <section id="consecuencias" class="section-shell section-light bg-gradient-to-b from-white to-red-50/30">
      <div class="page-container-wide">
        <div class="section-intro section-intro-center max-w-3xl mx-auto mb-10">
          <h2 class="section-title text-[#1E293B] text-2xl md:text-3xl font-bold mb-4">
            {config.consequencesTitle}
          </h2>
          <p class="section-copy text-[#475569] text-lg">
            {config.consequencesDescription}
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
          {config.consequences.map((item) => (
            <div class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-lg bg-red-50 flex items-center justify-center shrink-0 mt-0.5">
                  <Icon name={item.icon} size="sm" class="text-red-500" />
                </div>
                <div>
                  <h3 class="text-base font-bold text-[#1E293B] mb-1">{item.title}</h3>
                  <p class="text-[#475569] text-sm leading-relaxed">{item.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="text-center">
          <a href={config.primaryCtaHref} class="inline-flex items-center gap-2 bg-slate-900 hover:bg-slate-800 text-white font-semibold px-6 py-3 rounded-lg transition-colors">
            Solicitar diagnóstico gratis por WhatsApp
            <Icon name="fa-arrow-right" size="sm" />
          </a>
        </div>
      </div>
    </section>
  )}

  {config.offerTitle && (
    <section id="oferta" class="section-shell bg-slate-50">
      <div class="page-container max-w-4xl">
        <div class="bg-white rounded-2xl p-8 md:p-10 shadow-sm border border-slate-100">
          <div class="section-intro section-intro-center mb-8">
            <h2 class="section-title text-slate-900 text-2xl md:text-3xl font-bold mb-4">
              {config.offerTitle}
            </h2>
            <p class="section-copy text-slate-600 text-lg leading-relaxed max-w-2xl mx-auto">
              {config.offerDescription}
            </p>
          </div>

          <div class="space-y-4 mb-8 max-w-2xl mx-auto">
            {config.offerPoints?.map((point) => (
              <div class="flex items-start gap-3 p-3 bg-slate-50 rounded-lg">
                <div class="w-6 h-6 rounded-full bg-green-100 flex items-center justify-center shrink-0 mt-0.5">
                  <Icon name="fa-check" size="xs" class="text-green-600" />
                </div>
                <p class="text-slate-700 leading-relaxed">{point}</p>
              </div>
            ))}
          </div>

          <div class="text-center">
            <a href={config.primaryCtaHref} class="inline-flex items-center gap-2 bg-slate-900 hover:bg-slate-800 text-white font-semibold px-8 py-4 rounded-lg transition-colors text-lg">
              Quiero ordenar mi operación
              <Icon name="fa-arrow-right" size="sm" />
            </a>
          </div>
        </div>
      </div>
    </section>
  )}



  {config.methodologySteps && config.methodologySteps.length > 0 && (
    <section id="metodologia" class="section-shell section-light">
      <div class="page-container">
        <div class="section-intro section-intro-center">
          <h2 class="section-title text-[#1E293B]">
            {config.methodologyTitle}
          </h2>
          <p class="section-copy text-[#475569]">
            {config.methodologySubtitle}
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {config.methodologySteps.map((step) => (
            <div class="surface-card surface-panel p-6 flex flex-col h-full">
              <div class="flex items-center gap-4 mb-4">
                <span class="service-methodology-number w-12 h-12 rounded-xl flex items-center justify-center text-xl font-bold shrink-0">
                  {step.step}
                </span>
                <div class="service-icon-badge w-12 h-12 rounded-xl flex items-center justify-center shadow-lg">
                  <Icon name={step.icon} size="lg" class="text-white" />
                </div>
              </div>
              <h3 class="text-lg font-bold text-[#1E293B] mb-2">{step.title}</h3>
              <p class="text-sm text-[#475569] leading-relaxed mb-4 flex-1">{step.description}</p>
              <ul class="space-y-2">
                {step.items.map((item) => (
                  <li class="text-sm text-[#475569] flex items-start gap-2">
                    <span class="service-accent-text shrink-0 mt-0.5">•</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {config.workflow.length > 0 && (
    <section id="como-funciona" class="section-shell section-muted">
      <div class="page-container">
        <div class="section-intro section-intro-center">
          <h2 class="section-title text-slate-950">
            {config.workflowTitle}
          </h2>
          <p class="section-copy text-slate-600">
            {config.workflowSubtitle}
          </p>
        </div>

        <div class="space-y-6">
          {config.workflow.map((level) => (
            <FlowLevel level={level} surface="light" />
          ))}
        </div>
      </div>
    </section>
  )}

  {config.beforeAfterCases && config.beforeAfterCases.length > 0 && (
    <section id="antes-despues" class="section-shell section-light bg-slate-50">
      <div class="page-container">
        <div class="section-intro section-intro-center mb-12">
          <h2 class="section-title text-slate-950 text-3xl md:text-4xl font-bold">
            {config.beforeAfterTitle ?? 'Así cambia tu operación'}
          </h2>
          <p class="section-copy text-slate-600 text-lg max-w-3xl mx-auto mt-4">
            {config.beforeAfterSubtitle ?? 'Ejemplos concretos de cómo cambia el día a día cuando ordenás y automatizás tus procesos.'}
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 lg:gap-8 max-w-5xl mx-auto">
          {config.beforeAfterCases.map((item) => (
            <article class="bg-white rounded-2xl p-6 shadow-sm border border-slate-200 hover:shadow-md transition-shadow">
              <div class="flex items-center gap-3 mb-5">
                <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center shrink-0">
                  <Icon name={item.icon} size="lg" class="text-slate-700" />
                </div>
                <div>
                  <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">{item.industry}</span>
                  <h3 class="text-lg font-bold text-slate-900 leading-tight">{item.title}</h3>
                </div>
              </div>

              <div class="space-y-3">
                <div class="bg-red-50 border-l-4 border-red-400 p-4 rounded-r-lg">
                  <p class="text-xs font-bold uppercase tracking-wider text-red-600 mb-1">Antes</p>
                  <p class="text-sm text-slate-700 leading-relaxed">{item.before}</p>
                </div>

                <div class="flex justify-center py-1">
                  <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center">
                    <Icon name="fa-arrow-down" size="sm" class="text-slate-500" />
                  </div>
                </div>

                <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded-r-lg">
                  <p class="text-xs font-bold uppercase tracking-wider text-green-600 mb-1">Después</p>
                  <p class="text-sm text-slate-700 leading-relaxed">{item.after}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <section id="casos-aplicaciones" class="section-shell section-light">
    <div class="page-container">
      <div class="section-intro section-intro-center max-w-3xl mx-auto mb-12">
        <h2 class="section-title text-[#1E293B] text-2xl md:text-3xl font-bold mb-4">
          {config.casesTitle}
        </h2>
        <p class="section-copy text-[#475569] text-lg">
          {config.casesSubtitle}
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {config.cases.map((item) => (
          <article class="bg-white p-5 rounded-xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow flex flex-col">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg bg-slate-100 flex items-center justify-center shrink-0">
                <Icon name={item.icon} size="md" class="text-slate-700" />
              </div>
              <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">{item.label}</span>
            </div>

            <h3 class="text-base font-bold text-[#1E293B] mb-3 leading-snug">{item.title}</h3>

            <div class="space-y-2 flex-1">
              <p class="text-sm text-[#475569] leading-relaxed">
                <span class="font-medium text-red-600">Dolor:</span> {item.challenge}
              </p>
              <p class="text-sm text-[#475569] leading-relaxed">
                <span class="font-medium text-green-600">Resultado:</span> {item.result}
              </p>
            </div>

            <div class="mt-4 pt-3 border-t border-slate-100">
              <p class="text-xs text-slate-500">
                <span class="font-medium">Herramientas:</span> {item.stack}
              </p>
            </div>
          </article>
        ))}
      </div>

      {config.casesCta && (
        <div class="surface-card surface-panel mt-10 p-8 md:p-10 text-center">
          <h3 class="text-2xl md:text-3xl font-bold text-[#1E293B] mb-4">
            {config.casesCta.title}
          </h3>
          <p class="mx-auto max-w-3xl text-[#475569] leading-relaxed mb-6">
            {config.casesCta.description}
          </p>
          <a href={config.casesCta.ctaHref} class="action-primary">
            {config.casesCta.ctaLabel}
            <i class="fas fa-arrow-right text-xs"></i>
          </a>
        </div>
      )}
    </div>
  </section>

  {config.idealForSection && (
    <section id="para-quien" class="section-shell section-light">
      <div class="page-container">
        <div class="section-intro section-intro-center mb-12">
          <h2 class="section-title text-slate-950">
            {config.idealForSection.title}
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <div class="surface-card p-8 border-l-4 border-green-500">
            <h3 class="text-xl font-bold text-slate-950 mb-6 flex items-center gap-3">
              <span class="w-8 h-8 rounded-full bg-green-500 flex items-center justify-center text-white text-sm">✓</span>
              {config.idealForSection.yesTitle}
            </h3>
            <ul class="space-y-4">
              {config.idealForSection.yesItems.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="text-green-500 mt-1 shrink-0">✓</span>
                  <span class="text-slate-600">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="surface-card p-8 border-l-4 border-red-400">
            <h3 class="text-xl font-bold text-slate-950 mb-6 flex items-center gap-3">
              <span class="w-8 h-8 rounded-full bg-red-400 flex items-center justify-center text-white text-sm">×</span>
              {config.idealForSection.noTitle}
            </h3>
            <ul class="space-y-4">
              {config.idealForSection.noItems.map((item) => (
                <li class="flex items-start gap-3">
                  <span class="text-red-400 mt-1 shrink-0">×</span>
                  <span class="text-slate-600">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  )}

  {config.capabilities.length > 0 && (
    <section id="capacidades" class="section-shell section-dark">
      <div class="page-container">
        <div class="section-intro section-intro-center">
          <h2 class="section-title text-white">
            {config.capabilitiesTitle}
          </h2>
          <p class="section-copy text-slate-300">
            {config.capabilitiesSubtitle}
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {config.capabilities.map((capability) => (
            <div class="service-card surface-card-dark p-8 transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl hover:border-white/20 flex flex-col relative overflow-hidden backdrop-blur-sm">
              <div class="service-card-glow absolute -top-10 -right-10 w-32 h-32 rounded-full blur-2xl"></div>

              <div class="service-icon-badge w-16 h-16 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
                <Icon name={capability.icon} size="2xl" class="text-white" />
              </div>

              <h3 class="text-xl font-bold text-white mb-4">{capability.title}</h3>

              <div class="flex-1 space-y-4">
                <p class="text-sm text-slate-300 leading-relaxed">
                  <strong class="text-rose-300">Dolor:</strong> {capability.pain}
                </p>
                <p class="text-sm text-slate-300 leading-relaxed">
                  <strong class="text-blue-300">Solución:</strong> {capability.solution}
                </p>
                <p class="text-sm text-slate-300 leading-relaxed">
                  <strong class="text-green-300">Resultado:</strong> {capability.outcome}
                </p>

                <div>
                  <p class="text-sm text-white font-semibold mb-2">Incluye:</p>
                  <ul class="space-y-1.5">
                    {capability.bullets.map((bullet) => (
                      <li class="text-sm text-slate-400 pl-4 relative">
                        <span class="service-accent-text absolute left-0">•</span>
                        {bullet}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section id="prueba" class="section-shell section-light">
    <div class="page-container">
      <div class="section-intro section-intro-center">
        <h2 class="section-title text-slate-950">
          {config.proofTitle}
        </h2>
        <p class="section-copy text-slate-600">
          {config.proofSubtitle}
        </p>
      </div>

      <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] items-start">
        <div class="grid gap-4 md:grid-cols-3">
          {config.proofMetrics.map((metric) => (
            <article class="surface-card p-6 h-full">
              <p class="service-accent-text text-2xl font-bold mb-3">{metric.value}</p>
              <p class="text-sm font-semibold text-slate-950 mb-2">{metric.label}</p>
              <p class="text-sm text-slate-600 leading-relaxed">{metric.detail}</p>
            </article>
          ))}
        </div>

        <div class="space-y-4">
          {config.proofPoints.map((point) => (
            <article class="surface-card p-6 flex items-start gap-4">
              <div class="service-icon-soft w-12 h-12 rounded-xl flex items-center justify-center shrink-0">
                <Icon name={point.icon} size="lg" class="service-accent-text" />
                </div>
                <div>
                  <h3 class="text-lg font-bold text-slate-950 mb-2">{point.title}</h3>
                  <p class="text-sm text-slate-600 leading-relaxed">{point.description}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  {config.stackGroups.length > 0 && (
    <section id="stack" class="section-shell section-dark">
      <div class="page-container">
        <div class="section-intro section-intro-center">
          <h2 class="section-title text-white">
            {config.stackTitle}
          </h2>
          <p class="section-copy text-slate-300">
            {config.stackSubtitle}
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {config.stackGroups.map((group) => (
            <div class="service-card surface-card-dark p-6 backdrop-blur-sm">
              <div class="service-icon-soft w-12 h-12 rounded-xl flex items-center justify-center mb-4">
                <Icon name={group.icon} size="lg" class="service-accent-text" />
              </div>
              <h3 class="text-xl font-bold text-white mb-2">{group.title}</h3>
              <p class="text-sm text-slate-300 leading-relaxed mb-4">{group.description}</p>
              <ul class="space-y-2">
                {group.items.map((item) => (
                  <li class="text-sm text-slate-400 flex items-start gap-2">
                    <span class="service-accent-text shrink-0">•</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section id="diferenciacion" class="section-shell section-dark">
    <div class="page-container">
      <div class="section-intro section-intro-center">
        <h2 class="section-title text-white">
          {config.differentiationTitle}
        </h2>
        <p class="section-copy text-slate-300">
          {config.differentiationSubtitle}
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
        {config.differentiators.map((item) => (
          <div class="service-card surface-card-dark p-6 hover:bg-white/10 transition-colors backdrop-blur-sm">
            <div class="service-icon-soft w-12 h-12 rounded-xl flex items-center justify-center mb-4">
              <Icon name={item.icon} size="lg" class="service-accent-text" />
            </div>
            <h3 class="text-xl font-bold text-white mb-1">{item.title}</h3>
            <p class="service-accent-text text-sm font-medium mb-3">{item.subtitle}</p>
            <p class="text-slate-300 text-sm leading-relaxed mb-4">{item.description}</p>
            <div class="border-t border-white/10 pt-3">
              <p class="text-xs text-green-400 font-medium">
                <Icon name="fa-check-circle" class="inline mr-1" />
                {item.highlight}
              </p>
            </div>
          </div>
        ))}
      </div>

      <div class="bg-gradient-to-br from-red-500/10 to-red-600/10 border border-red-500/30 rounded-2xl p-8">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-red-500/30 flex items-center justify-center shrink-0">
            <Icon name="fa-times-circle" size="lg" class="text-red-400" />
          </div>
          <div class="flex-1">
            <h3 class="text-2xl font-bold text-white mb-4">{config.notIdealTitle}</h3>
            <p class="text-slate-300 mb-4">{config.notIdealIntro}</p>
            <ul class="space-y-3">
              {config.notIdealItems.map((item) => (
                <li class="flex items-start gap-3 text-slate-300">
                  <span class="text-red-400 font-bold shrink-0">×</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  {config.execution.bullets.length > 0 && (
    <section class="section-shell section-light">
      <div class="page-container-wide grid gap-8 lg:grid-cols-[1.1fr_0.9fr] items-start">
        <div>
          <p class="section-eyebrow text-slate-500">{config.execution.eyebrow ?? 'Quién ejecuta'}</p>
          <h2 class="section-title text-slate-950">
            {config.execution.title}
          </h2>
          <p class="section-copy text-slate-600">
            {config.execution.description}
          </p>
        </div>

        <aside class="surface-card surface-panel p-8">
          <p class="section-eyebrow text-slate-500">Señales de confianza</p>
          <ul class="space-y-3 text-slate-600">
            {config.execution.bullets.map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 text-slate-950">•</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <a
            href="/sobre-mi"
            class="action-primary mt-6"
          >
            {config.execution.ctaLabel ?? 'Ver experiencia y enfoque'}
            <i class="fas fa-arrow-right text-xs"></i>
          </a>
        </aside>
      </div>
    </section>
  )}


  <section id="faq" class="section-shell section-light">
    <div class="page-container-text">
      <div class="section-intro section-intro-center">
        <h2 class="section-title text-[#1E293B]">
          {config.faqTitle}
        </h2>
        <p class="section-copy text-[#475569]">
          {config.faqSubtitle}
        </p>
      </div>

      <div class="space-y-4">
        {config.faqs.map((faq, index) => (
          <details class="surface-card overflow-hidden group">
            <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-slate-50 transition-colors">
              <div class="flex items-center gap-4">
                <span class="service-faq-badge w-8 h-8 rounded-full flex items-center justify-center font-bold text-sm shrink-0">
                  {index + 1}
                </span>
                <h3 class="text-lg font-semibold text-[#1E293B]">{faq.question}</h3>
              </div>
              <Icon
                name="fa-chevron-down"
                class="text-slate-400 transition-transform duration-300 group-open:rotate-180"
              />
            </summary>
            <div class="px-6 pb-6 pt-2">
              <div class="pl-12">
                <p class="text-[#475569] leading-relaxed whitespace-pre-line">{faq.answer}</p>
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Contact content={config.contact} theme={config.theme} />
</main>

