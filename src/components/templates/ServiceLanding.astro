---
import FlowLevel from '../molecules/FlowLevel.astro';
import Icon from '../atoms/Icon.astro';
import ContactStrip from '../sections/ContactStrip.astro';
import type { ServiceLandingConfig } from '../../types/serviceLanding';

interface Props {
  config: ServiceLandingConfig;
}

const { config } = Astro.props;
---

<main>
  <section id="inicio" class="relative min-h-screen bg-gradient-to-br from-[#0F172A] to-[#1E293B] text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.15) 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 pt-24 pb-16 min-h-screen flex flex-col justify-center gap-12">
      <div class="max-w-4xl">
        <span class="inline-block px-4 py-2 bg-blue-500/20 text-blue-300 text-sm font-semibold rounded-full border border-blue-500/30 mb-6">
          {config.badge}
        </span>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
          {config.title}
        </h1>

        <p class="text-xl md:text-2xl text-slate-300 mb-8 leading-relaxed max-w-4xl">
          {config.subtitle}
        </p>

        <div class="grid sm:grid-cols-3 gap-4 mb-10">
          {config.benefits.map((benefit) => (
            <div class="flex items-start gap-3">
              <span class="text-green-400 text-xl shrink-0">✓</span>
              <span class="text-slate-300">{benefit}</span>
            </div>
          ))}
        </div>

        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a
            href={config.primaryCtaHref}
            class="px-8 py-4 bg-gradient-to-r from-blue-500 to-blue-600 text-white font-bold rounded-xl text-lg text-center transition-all duration-300 hover:from-blue-600 hover:to-blue-700 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-blue-500/25 border border-blue-500/30"
          >
            {config.primaryCtaLabel} →
          </a>
          <a
            href={config.secondaryCtaHref}
            class="px-8 py-4 bg-white/10 hover:bg-white/20 text-white font-bold rounded-xl text-lg text-center transition-all duration-300 border border-white/20"
          >
            {config.secondaryCtaLabel}
          </a>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {config.metrics.map((metric) => (
            <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
              <p class="text-2xl font-bold text-blue-400 mb-2">{metric.value}</p>
              <p class="text-sm text-slate-300">{metric.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="problema" class="py-24 px-6 bg-[#F8FAFC]">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-[#1E293B] mb-6">
          {config.problemTitle}
        </h2>
        <p class="text-xl text-[#475569] max-w-4xl mx-auto leading-relaxed">
          {config.problemSubtitle}
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {config.problemCards.map((card) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-xl bg-red-100 flex items-center justify-center mb-4">
              <Icon name={card.icon} size="lg" class="text-red-600" />
            </div>
            <h3 class="text-lg font-bold text-[#1E293B] mb-2">{card.title}</h3>
            <p class="text-[#475569] text-sm leading-relaxed">{card.description}</p>
          </div>
        ))}
      </div>

      <div class="bg-gradient-to-r from-red-50 to-orange-50 border border-red-200 rounded-2xl p-8">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-full bg-red-500 flex items-center justify-center shrink-0">
            <Icon name="fa-exclamation" size="lg" class="text-white" />
          </div>
          <div>
            <h3 class="text-xl font-bold text-[#1E293B] mb-2">{config.riskTitle}</h3>
            <p class="text-[#475569] leading-relaxed">{config.riskDescription}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="capacidades" class="py-24 px-6 bg-gradient-to-br from-slate-900 to-slate-800">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
          {config.capabilitiesTitle}
        </h2>
        <p class="text-xl text-slate-300 max-w-4xl mx-auto">
          {config.capabilitiesSubtitle}
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {config.capabilities.map((capability) => (
          <div class="card bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl hover:border-white/20 flex flex-col relative overflow-hidden">
            <div class="absolute -top-10 -right-10 w-32 h-32 bg-blue-500/10 rounded-full blur-2xl"></div>

            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center mb-6 shadow-lg shadow-blue-500/25">
              <Icon name={capability.icon} size="2xl" class="text-white" />
            </div>

            <h3 class="text-xl font-bold text-white mb-4">{capability.title}</h3>

            <div class="flex-1 space-y-4">
              <p class="text-sm text-slate-300 leading-relaxed">
                <strong class="text-rose-300">Dolor:</strong> {capability.pain}
              </p>
              <p class="text-sm text-slate-300 leading-relaxed">
                <strong class="text-blue-300">Solución:</strong> {capability.solution}
              </p>
              <p class="text-sm text-slate-300 leading-relaxed">
                <strong class="text-green-300">Resultado:</strong> {capability.outcome}
              </p>

              <div>
                <p class="text-sm text-white font-semibold mb-2">Incluye:</p>
                <ul class="space-y-1.5">
                  {capability.bullets.map((bullet) => (
                    <li class="text-sm text-slate-400 pl-4 relative">
                      <span class="absolute left-0 text-blue-400">•</span>
                      {bullet}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="como-funciona" class="py-24 px-6 bg-gradient-to-br from-slate-900 to-slate-800">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
          {config.workflowTitle}
        </h2>
        <p class="text-xl text-slate-300 max-w-4xl mx-auto">
          {config.workflowSubtitle}
        </p>
      </div>

      <div class="space-y-6">
        {config.workflow.map((level) => (
          <FlowLevel level={level} />
        ))}
      </div>
    </div>
  </section>

  <section id="casos-aplicaciones" class="py-24 px-6 bg-[#F8FAFC]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold text-[#1E293B] mb-4">
          {config.casesTitle}
        </h2>
        <p class="text-xl text-[#475569] max-w-4xl mx-auto">
          {config.casesSubtitle}
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {config.cases.map((item) => (
          <article class="bg-white rounded-2xl p-8 shadow-sm border border-slate-200 hover:shadow-lg transition-shadow flex flex-col">
            <div class="flex items-center justify-between mb-4">
              <Icon name={item.icon} size="2xl" class="text-blue-600" />
              <span class="text-xs uppercase tracking-wider px-3 py-1 rounded-full bg-blue-50 border border-blue-100 text-blue-700 font-semibold">
                {item.label}
              </span>
            </div>

            <h3 class="text-xl font-bold text-[#1E293B] mb-4">{item.title}</h3>

            <div class="space-y-4 flex-1">
              <p class="text-sm text-[#475569] leading-relaxed">
                <strong class="text-[#1E293B]">Desafío:</strong> {item.challenge}
              </p>
              <p class="text-sm text-[#475569] leading-relaxed">
                <strong class="text-[#1E293B]">Enfoque:</strong> {item.approach}
              </p>
              <p class="text-sm text-[#475569] leading-relaxed">
                <strong class="text-[#1E293B]">Resultado esperado:</strong> {item.result}
              </p>
            </div>

            <div class="mt-6 pt-4 border-t border-slate-200">
              <p class="text-sm text-[#475569]">
                <strong class="text-[#1E293B]">Stack:</strong> {item.stack}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="stack" class="py-24 px-6 bg-gradient-to-br from-slate-900 to-slate-800">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
          {config.stackTitle}
        </h2>
        <p class="text-xl text-slate-300 max-w-4xl mx-auto">
          {config.stackSubtitle}
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {config.stackGroups.map((group) => (
          <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6">
            <div class="w-12 h-12 rounded-xl bg-blue-500/20 flex items-center justify-center mb-4">
              <Icon name={group.icon} size="lg" class="text-blue-400" />
            </div>
            <h3 class="text-xl font-bold text-white mb-2">{group.title}</h3>
            <p class="text-sm text-slate-300 leading-relaxed mb-4">{group.description}</p>
            <ul class="space-y-2">
              {group.items.map((item) => (
                <li class="text-sm text-slate-400 flex items-start gap-2">
                  <span class="text-blue-400 shrink-0">•</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="diferenciacion" class="py-24 px-6 bg-gradient-to-br from-slate-900 to-slate-800">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
          {config.differentiationTitle}
        </h2>
        <p class="text-xl text-slate-300 max-w-4xl mx-auto">
          {config.differentiationSubtitle}
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
        {config.differentiators.map((item) => (
          <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-colors">
            <div class="w-12 h-12 rounded-xl bg-blue-500/20 flex items-center justify-center mb-4">
              <Icon name={item.icon} size="lg" class="text-blue-400" />
            </div>
            <h3 class="text-xl font-bold text-white mb-1">{item.title}</h3>
            <p class="text-sm text-blue-400 font-medium mb-3">{item.subtitle}</p>
            <p class="text-slate-300 text-sm leading-relaxed mb-4">{item.description}</p>
            <div class="border-t border-white/10 pt-3">
              <p class="text-xs text-green-400 font-medium">
                <Icon name="fa-check-circle" class="inline mr-1" />
                {item.highlight}
              </p>
            </div>
          </div>
        ))}
      </div>

      <div class="bg-gradient-to-br from-red-500/10 to-red-600/10 border border-red-500/30 rounded-2xl p-8">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 rounded-xl bg-red-500/30 flex items-center justify-center shrink-0">
            <Icon name="fa-times-circle" size="lg" class="text-red-400" />
          </div>
          <div class="flex-1">
            <h3 class="text-2xl font-bold text-white mb-4">{config.notIdealTitle}</h3>
            <p class="text-slate-300 mb-4">{config.notIdealIntro}</p>
            <ul class="space-y-3">
              {config.notIdealItems.map((item) => (
                <li class="flex items-start gap-3 text-slate-300">
                  <span class="text-red-400 font-bold shrink-0">×</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="faq" class="py-24 px-6 bg-[#F8FAFC]">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold text-[#1E293B] mb-4">
          {config.faqTitle}
        </h2>
        <p class="text-xl text-[#475569]">
          {config.faqSubtitle}
        </p>
      </div>

      <div class="space-y-4">
        {config.faqs.map((faq, index) => (
          <details class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden group">
            <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-slate-50 transition-colors">
              <div class="flex items-center gap-4">
                <span class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold text-sm shrink-0">
                  {index + 1}
                </span>
                <h3 class="text-lg font-semibold text-[#1E293B]">{faq.question}</h3>
              </div>
              <Icon
                name="fa-chevron-down"
                class="text-slate-400 transition-transform duration-300 group-open:rotate-180"
              />
            </summary>
            <div class="px-6 pb-6 pt-2">
              <div class="pl-12">
                <p class="text-[#475569] leading-relaxed whitespace-pre-line">{faq.answer}</p>
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <ContactStrip
    eyebrow={config.contact.eyebrow}
    title={config.contact.title}
    description={config.contact.description}
  />
</main>

<style>
  details > summary::-webkit-details-marker {
    display: none;
  }

  details > summary {
    list-style: none;
  }
</style>
