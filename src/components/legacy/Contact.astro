---
import '../styles/contact.css'

// Variables de contacto - Configurar con datos reales
const CONTACT_EMAIL = "variable_email@dominio.com";
const WHATSAPP_NUMBER = "XXXXXXXXXXX";
const WHATSAPP_DISPLAY = "+XX XXX-XXX-XXXX";
const CALENDLY_URL = "https://calendly.com/tu-agenda/15min";
---

<section class="contact-page-two" id="contacto">
    <div class="contact-card-two">

        <!-- Lado de información de contacto -->
        <div class="info-sidebar">
            <h2>Hablemos</h2>

            <div class="contact-detail-item">
                <div class="contact-text">
                    <p class="label">Correo directo</p>
                    <p class="value"><a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a></p>
                </div>
            </div>

            <div class="contact-detail-item">
                <div class="contact-text">
                    <p class="label">WhatsApp personal</p>
                    <p class="value"><a href={`https://wa.me/${WHATSAPP_NUMBER}`}>{WHATSAPP_DISPLAY}</a></p>
                </div>
            </div>

            <div class="contact-detail-item">
                <div class="contact-text">
                    <p class="label">Agenda una llamada</p>
                    <p class="value"><a href={CALENDLY_URL} target="_blank">Agendar 15 min</a></p>
                </div>
            </div>
        </div>


        <!-- Lado de formulario -->
        <div class="form-area-two">
            <h3>Agenda tu consulta gratuita</h3>
            <p class="form-instruction">Cuéntame sobre tu operación y te propongo una solución personalizada. Respondo directamente en menos de 1 hora.</p>

            <div class="quick-actions">
                <a class="quick-btn primary" href={CALENDLY_URL} target="_blank">Agendar llamada 15 min</a>
                <a class="quick-btn ghost" href={`https://wa.me/${WHATSAPP_NUMBER}`}>Escríbeme por WhatsApp</a>
            </div>

            <form class="clean-form">

                <div class="form-group-two">
                    <label for="your-name-two">Nombre</label>
                    <input type="text" id="your-name-two" name="name" placeholder="Tu nombre completo" required>
                </div>

                <div class="form-group-two">
                    <label for="your-company-two">Empresa</label>
                    <input type="text" id="your-company-two" name="company" placeholder="Nombre de la empresa">
                </div>

                <div class="form-group-two">
                    <label for="your-email-two">Correo electrónico</label>
                    <input type="email" id="your-email-two" name="email" placeholder="correo@ejemplo.com" required>
                </div>

                <div class="form-group-two">
                    <label for="your-topic-two">¿Qué necesitas gestionar en campo?</label>
                    <select id="your-topic-two" name="topic" required>
                        <option value="" selected disabled>Selecciona tu sector o necesidad</option>
                        <option value="seguridad-trazabilidad">Seguridad de datos y trazabilidad completa</option>
                        <option value="inspecciones-tecnicas">Inspecciones técnicas con evidencia</option>
                        <option value="asignaciones-campo">Asignaciones y seguimiento de equipos de campo</option>
                        <option value="captura-datos">Captura de datos con validación (fotos, GPS, formularios)</option>
                        <option value="auditoria-cumplimiento">Auditoría y cumplimiento normativo</option>
                        <option value="metricas-kpis">Dashboards con métricas y KPIs en tiempo real</option>
                        <option value="integracion-erp">Integración con ERP o sistemas actuales</option>
                        <option value="otro">Otro / No estoy seguro</option>
                    </select>
                </div>

                <div class="form-group-two">
                    <label for="your-message-two">Cuéntame sobre tu operación</label>
                    <textarea id="your-message-two" name="message" rows="4"
                        placeholder="Ej: Tenemos 30 técnicos de campo que hacen instalaciones. Usan papel y WhatsApp. Necesitamos asignarles tareas y ver el avance en tiempo real." required></textarea>
                </div>

                <p class="privacy-note">Usaré tus datos solo para responder a tu consulta. Respuesta directa garantizada.</p>

                <button type="submit" class="send-button-two">
                    Enviar mensaje
                </button>
            </form>
        </div>
    </div>
</section>
