---
import '../styles/hero.css'
---
<section class="hero" id="home">
  <div class="background-decor">
    <span class="circle c1"></span>
    <span class="circle c2"></span>
    <span class="circle c3"></span>
    <span class="circle c4"></span>
    <span class="circle c5"></span>
  </div>

  <div class="container_hero">
    <div class="hero_display">
      <div class="contenido_hero_text">
        <h1 class="hero-title animate-fade">¿Excel, WhatsApp y correos controlan tus operaciones en lugar de sistemas confiables?</h1>

        <p class="hero-promise animate-slide">Paso tus operaciones de procesos manuales a sistemas end-to-end: captura, validación, integración, ML/IA y decisiones en horas, no días.</p>

        <div class="hero-metrics animate-fade-delay">
          <div class="metric">
            <span class="metric-value">+5M</span>
            <span class="metric-label">documentos procesados</span>
          </div>
          <div class="metric">
            <span class="metric-value">10×</span>
            <span class="metric-label">más rápido</span>
          </div>
          <div class="metric">
            <span class="metric-value">-60%</span>
            <span class="metric-label">errores</span>
          </div>
        </div>

        <div class="hero-trust animate-fade-delay">
          <p><strong>+10 años</strong> • <strong>+10 proyectos en producción</strong> • Energía • Agricultura • Manufactura • Minería • Forestal</p>
          <p class="hero-response">Respondo en &lt;1 hora hábil</p>
        </div>

        <div class="hero-buttons animate-slide-delay">
          <a href="#contacto" class="btn-primary">Agenda 15 min</a>
          <a href="https://wa.me/XXXXXXXXXXX" class="btn-secondary">Escríbeme en WhatsApp</a>
        </div>
      </div>

      <div class="hero-image animate-float">
        <img src="/imagen.png" alt="Imagen profesional de tecnología y datos">
      </div>
    </div>
  </div>
</section>
