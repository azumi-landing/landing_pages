---
import type { AreaEspecializacion } from '../../types';
import Icon from '../atoms/Icon.astro';

interface Props {
  area: AreaEspecializacion;
}

const { area } = Astro.props;
---

<div class="card bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:border-blue-500/30 min-w-[280px]">
  <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center mb-4 shadow-lg shadow-blue-500/25">
    <Icon name={area.icon} size="xl" class="text-white" />
  </div>
  
  <h3 class="text-lg font-bold text-white mb-2">{area.title}</h3>
  
  <p class="text-sm text-slate-400 mb-4 leading-relaxed">{area.description}</p>
  
  <div class="flex flex-wrap gap-2">
    {area.keywords.map((keyword) => (
      <span class="text-xs text-blue-300 bg-blue-500/10 px-3 py-1.5 rounded-full border border-blue-500/20">
        {keyword}
      </span>
    ))}
  </div>
</div>
