---
import Icon from '../atoms/Icon.astro';

interface WorkflowStep {
  phase: string;
  title: string;
  description: string;
  icon: string;
  actor: 'web' | 'mobile' | 'both';
}

interface Props {
  steps: WorkflowStep[];
  sectorName: string;
}

const { steps, sectorName } = Astro.props;

const phaseColors: Record<string, string> = {
  'Planificación': 'bg-purple-100 text-purple-700 border-purple-200',
  'Asignación': 'bg-blue-100 text-blue-700 border-blue-200',
  'Ejecución': 'bg-green-100 text-green-700 border-green-200',
  'Supervisión': 'bg-yellow-100 text-yellow-700 border-yellow-200',
  'Auditoría': 'bg-orange-100 text-orange-700 border-orange-200',
  'Cierre': 'bg-teal-100 text-teal-700 border-teal-200',
  'Analítica': 'bg-indigo-100 text-indigo-700 border-indigo-200'
};

const actorLabels = {
  'web': 'Web',
  'mobile': 'App Móvil',
  'both': 'Web + App'
};
---

<div class="workflow-timeline bg-slate-50 rounded-xl p-6 border border-slate-200">
  <h3 class="text-lg font-bold text-slate-800 mb-6 text-center">
    Flujo de trabajo en {sectorName}
  </h3>
  
  <div class="relative">
    <!-- Timeline line -->
    <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-0.5 bg-slate-300 transform -translate-x-1/2"></div>
    
    <div class="space-y-6 md:space-y-8">
      {steps.map((step, index) => (
        <div class={`relative flex flex-col md:flex-row gap-4 ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
          <!-- Content card -->
          <div class={`flex-1 ${index % 2 === 0 ? 'md:text-right md:pr-8' : 'md:text-left md:pl-8'}`}>
            <div class={`inline-block p-4 rounded-lg border-2 bg-white shadow-sm hover:shadow-md transition-shadow ${phaseColors[step.phase] || 'bg-slate-100 border-slate-200'}`}>
              <div class={`flex items-center gap-2 mb-2 ${index % 2 === 0 ? 'md:justify-end' : ''}`}>
                <span class="text-xs font-bold uppercase tracking-wider px-2 py-1 rounded bg-white/50">
                  {step.phase}
                </span>
                <span class="text-xs text-slate-500 flex items-center gap-1">
                  <i class={`fas fa-${step.actor === 'web' ? 'desktop' : step.actor === 'mobile' ? 'mobile-alt' : 'sync'}`}></i>
                  {actorLabels[step.actor]}
                </span>
              </div>
              <h4 class="font-bold text-slate-800 mb-1">{step.title}</h4>
              <p class="text-sm text-slate-600 leading-relaxed">{step.description}</p>
            </div>
          </div>
          
          <!-- Center icon -->
          <div class="absolute left-1/2 transform -translate-x-1/2 w-10 h-10 rounded-full bg-white border-2 border-slate-300 flex items-center justify-center shadow-sm z-10 hidden md:flex">
            <Icon name={step.icon} size="sm" class="text-slate-600" />
          </div>
          
          <!-- Spacer for alternating layout -->
          <div class="flex-1 hidden md:block"></div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .workflow-timeline {
    position: relative;
  }
  
  @media (max-width: 768px) {
    .workflow-timeline::before {
      content: '';
      position: absolute;
      left: 20px;
      top: 80px;
      bottom: 20px;
      width: 2px;
      background: #CBD5E1;
    }
  }
</style>
