---
import type { AppMockup as AppMockupType } from '../../types';

interface Props {
  app: AppMockupType;
}

const { app } = Astro.props;

const statusClasses = {
  urgent: 'bg-red-100 text-red-600',
  progress: 'bg-blue-100 text-blue-700',
  done: 'bg-green-100 text-green-600',
  neutral: 'bg-gray-100 text-gray-600'
};

const statusLabels = {
  urgent: 'Alerta',
  progress: 'En revisión',
  done: 'Completado',
  neutral: 'Pendiente'
};
---

<div class="w-[220px] h-[420px] bg-[#1a1a1a] rounded-[30px] p-3 mx-auto shadow-2xl relative">
  <!-- Notch -->
  <div class="absolute top-2 left-1/2 -translate-x-1/2 w-20 h-5 bg-[#1a1a1a] rounded-b-xl z-10"></div>
  
  <!-- Screen -->
  <div class="w-full h-full bg-[#f5f5f5] rounded-[20px] overflow-hidden flex flex-col">
    <!-- Header -->
    <div class="bg-[#1E3A8A] text-white pt-9 pb-4 px-4 text-center">
      <h4 class="text-sm font-semibold m-0">{app.title}</h4>
      <p class="text-xs opacity-90 mt-1">{app.user}</p>
    </div>
    
    <!-- Content -->
    <div class="flex-1 p-4 overflow-y-auto">
      {app.cards.map((card) => (
        <div class="bg-white rounded-xl p-3 mb-3 shadow-sm">
          <div class="flex justify-between items-center mb-2">
            <span class="text-xs font-semibold text-[#1E293B]">{card.title}</span>
            <span class={`text-xs px-2 py-1 rounded-full font-medium ${statusClasses[card.status]}`}>
              {statusLabels[card.status]}
            </span>
          </div>
          <p class="text-xs text-[#64748B] m-0 leading-relaxed" set:html={card.details}></p>
          <div class="flex gap-2 mt-2 text-xs text-[#94A3B8]">
            {card.meta.map((meta) => (
              <span>{meta}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
    
    <!-- Actions -->
    <div class="flex gap-2 p-4 bg-white border-t border-[#E2E8F0]">
      {app.actions.map((action, index) => (
        <button 
          class={`flex-1 py-2.5 rounded-lg text-xs font-semibold ${
            action.variant === 'primary' 
              ? 'bg-[#1E3A8A] text-white' 
              : 'bg-[#F1F5F9] text-[#475569]'
          }`}
        >
          {action.label}
        </button>
      ))}
    </div>
  </div>
</div>
