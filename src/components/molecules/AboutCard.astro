---
import type { AboutCard } from '../../types';
import Icon from '../atoms/Icon.astro';

interface Props {
  card: AboutCard;
}

const { card } = Astro.props;
---

<div class="card bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 hover:border-blue-500/30">
  <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center mb-4 shadow-lg">
    <Icon name={card.icon} size="lg" class="text-white" />
  </div>
  
  <h3 class="text-lg font-bold text-white mb-3">{card.title}</h3>
  
  <ul class="space-y-2">
    {card.bullets.map((bullet) => (
      <li class="text-sm text-slate-300 leading-relaxed">
        <span set:html={bullet.replace(/<strong>(.+?)<\/strong>/g, '<strong class="text-white">$1</strong>')}></span>
      </li>
    ))}
  </ul>
</div>
