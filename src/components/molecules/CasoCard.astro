---
import type { CasoExito } from '../../types';
import Icon from '../atoms/Icon.astro';

interface Props {
  caso: CasoExito;
}

const { caso } = Astro.props;
---

<div class="card bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 transition-all duration-300 hover:-translate-y-2 hover:border-blue-500/50 hover:shadow-2xl flex flex-col">
  <!-- Header -->
  <div class="flex items-center justify-between mb-4">
    <Icon name={caso.sectorIcon} size="2xl" class="text-blue-500" />
    <span class="badge bg-blue-500/20 text-blue-400 border-blue-500/30 text-xs uppercase tracking-wider">
      {caso.sector}
    </span>
  </div>
  
  <!-- Title -->
  <h3 class="text-xl font-bold text-white mb-6 leading-snug min-h-[3.5rem]">
    {caso.title}
  </h3>
  
  <!-- Content -->
  <div class="flex-1 flex flex-col gap-4">
    <p class="text-sm text-slate-300 leading-relaxed">
      <strong class="text-white">Dolor:</strong> {caso.dolor}
    </p>
    
    <p class="text-sm text-slate-300 leading-relaxed">
      <strong class="text-white">Solución:</strong> {caso.solucion}
    </p>
    
    <p class="text-sm text-slate-300 mb-2">
      <strong class="text-white">Resultado:</strong>
    </p>
    
    <ul class="space-y-2 mb-4">
      {caso.metricas.map((metrica) => (
        <li class="text-sm text-slate-300 pl-6 relative leading-relaxed">
          <span class="absolute left-0 text-green-500 font-bold">✓</span>
          <span set:html={metrica.replace(/\*\*(.+?)\*\*/g, '<strong class="text-blue-400">$1</strong>')}></span>
        </li>
      ))}
    </ul>
    
    <!-- Tech details -->
    <details class="mt-auto pt-4 border-t border-white/10">
      <summary class="cursor-pointer text-sm text-slate-400 font-medium hover:text-blue-400 transition-colors">
        Detalle técnico
      </summary>
      <p class="mt-3 text-sm text-slate-400 p-3 bg-black/20 rounded-lg border-l-2 border-blue-500">
        <strong>Stack:</strong> {caso.stack}
      </p>
    </details>
  </div>
  
  <!-- CTA -->
  <a 
    href="#contacto" 
    class="mt-6 inline-block px-6 py-3 bg-gradient-to-r from-blue-500 to-blue-600 text-white font-semibold rounded-lg text-center transition-all duration-300 hover:from-blue-600 hover:to-blue-700 hover:-translate-y-0.5 hover:shadow-lg border border-blue-500/30"
  >
    Ver demo de la plataforma
  </a>
</div>
