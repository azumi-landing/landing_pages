---
import type { Servicio } from '../../types';
import { buildContactHref } from '../../data/contact';
import Icon from '../atoms/Icon.astro';

interface Props {
  servicio: Servicio;
}

const { servicio } = Astro.props;
const fieldOpsContactHref = buildContactHref({
  service: 'gestion-operaciones-de-campo',
  originPath: '/gestion-de-operaciones-de-campo',
  originLabel: 'Gestión de Operaciones de Campo'
});
---

<div class="surface-card p-8 transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_24px_60px_rgba(15,23,42,0.12)] flex flex-col relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute -top-10 -right-10 w-32 h-32 bg-blue-500/8 rounded-full blur-2xl"></div>
  
  <!-- Icon -->
  <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center mb-6 shadow-lg shadow-blue-500/25">
    <Icon name={servicio.icon} size="2xl" class="text-white" />
  </div>
  
  <!-- Title -->
  <h3 class="text-xl font-bold text-slate-950 mb-4">{servicio.title}</h3>
  
  <!-- Content -->
  <div class="flex-1 space-y-4">
    <p class="text-sm text-slate-600 leading-relaxed">
      <strong class="text-rose-600">Dolor:</strong> {servicio.pain}
    </p>
    
    <p class="text-sm text-slate-600 leading-relaxed">
      <strong class="text-blue-700">Solución:</strong> {servicio.promise}
    </p>
    
    <p class="text-sm text-slate-600 leading-relaxed">
      <strong class="text-emerald-700">Resultado:</strong> {servicio.proof}
    </p>
    
    <div>
      <p class="text-sm text-slate-950 font-semibold mb-2">Funcionalidades:</p>
      <ul class="space-y-1.5">
        {servicio.features.map((feature) => (
          <li class="text-sm text-slate-500 pl-4 relative">
            <span class="absolute left-0 text-blue-400">•</span>
            {feature}
          </li>
        ))}
      </ul>
    </div>
  </div>
  
  <!-- CTA -->
  <a 
    href={fieldOpsContactHref}
    class="action-primary mt-6"
  >
    {servicio.cta}
  </a>
</div>
