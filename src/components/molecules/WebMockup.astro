---
import type { DashboardMockup } from '../../types';

interface Props {
  dashboard: DashboardMockup;
}

const { dashboard } = Astro.props;
---

<div class="w-full max-w-md h-[280px] bg-[#1a1a1a] rounded-xl p-2 mx-auto shadow-xl">
  <!-- Browser bar -->
  <div class="flex items-center gap-1.5 p-2 bg-[#2d2d2d] rounded-t-md">
    <div class="w-2 h-2 rounded-full bg-[#ff5f57]"></div>
    <div class="w-2 h-2 rounded-full bg-[#febc2e]"></div>
    <div class="w-2 h-2 rounded-full bg-[#28c840]"></div>
    <div class="flex-1 bg-[#1a1a1a] py-1 px-3 rounded text-xs text-[#94A3B8] text-center">
      {dashboard.url}
    </div>
  </div>
  
  <!-- Screen -->
  <div class="h-[calc(100%-30px)] bg-[#f8fafc] rounded-b-md overflow-hidden flex">
    <!-- Sidebar -->
    <div class="w-[70px] bg-[#1E3A8A] py-4 px-2 flex flex-col gap-4">
      {dashboard.sidebarIcons.map((icon, index) => (
        <div class={`w-9 h-9 rounded-lg flex items-center justify-center text-white text-sm ${
          index === 0 ? 'bg-white/25' : 'bg-white/10'
        }`}>
          <i class={`fas ${icon}`}></i>
        </div>
      ))}
    </div>
    
    <!-- Content -->
    <div class="flex-1 p-4 overflow-hidden">
      <!-- Header -->
      <div class="flex justify-between items-center mb-4">
        <h5 class="text-sm font-semibold text-[#1E293B] m-0">{dashboard.title}</h5>
        <div class="w-7 h-7 bg-[#1E3A8A] rounded-full flex items-center justify-center text-white text-xs font-semibold">
          {dashboard.user.split(' ').map(n => n[0]).join('')}
        </div>
      </div>
      
      <!-- Stats -->
      <div class="grid grid-cols-3 gap-2 mb-4">
        {dashboard.stats.map((stat) => (
          <div class="bg-white p-2.5 rounded-lg shadow-sm">
            <p class="text-lg font-bold text-[#1E3A8A] m-0">{stat.value}</p>
            <p class="text-xs text-[#64748B] mt-0.5">{stat.label}</p>
          </div>
        ))}
      </div>
      
      <!-- Table -->
      <div class="bg-white rounded-lg overflow-hidden shadow-sm">
        <div class="grid grid-cols-3 p-2.5 bg-[#F1F5F9] text-xs font-semibold text-[#475569]">
          {dashboard.table.headers.map((header) => (
            <span>{header}</span>
          ))}
        </div>
        {dashboard.table.rows.map((row) => (
          <div class="grid grid-cols-3 p-2.5 border-b border-[#F1F5F9] last:border-b-0 text-xs text-[#64748B]">
            {row.map((cell) => (
              <span>{cell}</span>
            ))}
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
