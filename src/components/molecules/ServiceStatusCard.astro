---
import Badge from '../atoms/Badge.astro';
import Icon from '../atoms/Icon.astro';

interface Props {
  title: string;
  description: string;
  href: string;
  cta: string;
  icon: string;
  status: 'available' | 'coming-soon';
  highlight?: boolean;
}

const {
  title,
  description,
  href,
  cta,
  icon,
  status,
  highlight = false
} = Astro.props;

const statusLabel = status === 'available' ? 'Disponible' : 'Próximamente';
const badgeVariant = status === 'available' ? 'accent' : 'outline';
const cardClasses = highlight
  ? 'border-blue-500/40 bg-gradient-to-br from-blue-500/10 to-slate-900'
  : 'border-white/10 bg-white/5';
---

<article class={`rounded-2xl border p-8 transition-all duration-300 hover:-translate-y-1 hover:border-blue-500/40 ${cardClasses}`}>
  <div class="flex items-center justify-between gap-4 mb-6">
    <div class="w-14 h-14 rounded-2xl bg-blue-500/20 flex items-center justify-center shrink-0">
      <Icon name={icon} size="xl" class="text-blue-400" />
    </div>
    <Badge variant={badgeVariant} size="sm">{statusLabel}</Badge>
  </div>

  <h2 class="text-2xl font-bold text-white mb-3">{title}</h2>
  <p class="text-slate-300 leading-relaxed mb-8">{description}</p>

  <a
    href={href}
    class="inline-flex items-center gap-2 text-sm font-semibold text-white bg-white/10 hover:bg-white/20 border border-white/10 rounded-lg px-5 py-3 transition-colors"
  >
    {cta}
    <i class="fas fa-arrow-right text-xs"></i>
  </a>
</article>
