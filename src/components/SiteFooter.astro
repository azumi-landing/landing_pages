---
import LogoHG from './LogoHG.astro';
import { CONTACT_PAGE_PATH, getWhatsAppHref } from '../data/contact';
import { footerLinks, serviceLinks } from '../data/site';

const whatsappHref = getWhatsAppHref();
const primaryLinks = footerLinks.filter((link) => ['/', '/sobre-mi', '/contacto'].includes(link.href));
const legalLinks = footerLinks.filter((link) => ['/privacidad', '/terminos'].includes(link.href));
---

<footer class="border-t border-slate-800 bg-slate-950">
  <div class="page-container py-14">
    <div class="grid gap-12 lg:grid-cols-[1.25fr_0.8fr_0.9fr_0.8fr]">
      <div>
        <div class="flex items-center gap-3 mb-5">
          <LogoHG />
          <div>
            <p class="text-sm font-semibold text-white">HGuerra</p>
            <p class="text-sm text-slate-400">Consultoría aplicada para operación, producto y automatización</p>
          </div>
        </div>
        <h2 class="text-2xl font-bold text-white max-w-sm leading-tight mb-4">
          Criterio operativo, diseño de solución e implementación en una misma relación de trabajo.
        </h2>
        <p class="text-sm leading-relaxed text-slate-400 max-w-md">
          El sitio está organizado para ayudarte a identificar rápido si tu reto pide consultoría, automatización o una solución digital más aterrizada.
        </p>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500 mb-4">Principal</h2>
        <ul class="space-y-3 text-sm text-slate-400">
          {primaryLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500 mb-4">Servicios</h2>
        <ul class="space-y-3 text-sm text-slate-400">
          {serviceLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h2 class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500 mb-4">Contacto y legal</h2>
        <ul class="space-y-3 text-sm text-slate-400">
          <li>
            <a href={CONTACT_PAGE_PATH} class="hover:text-white transition-colors">Formulario</a>
          </li>
          <li>
            <a href={whatsappHref} class="hover:text-white transition-colors">WhatsApp</a>
          </li>
          {legalLinks.map((link) => (
            <li>
              <a href={link.href} class="hover:text-white transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</footer>
