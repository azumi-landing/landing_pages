---
import LogoHG from './LogoHG.astro';
import { contactConfig } from '../data/contact';

const footerLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/gestion-de-operaciones-de-campo', label: 'Gestión de Operaciones de Campo' },
  { href: '/automatizacion-con-ia-agentica', label: 'Automatización con IA Agéntica' },
  { href: '/automatizacion-de-procesos', label: 'Automatización de Procesos' }
];
---

<footer class="border-t border-slate-800 bg-slate-950">
  <div class="max-w-7xl mx-auto px-6 py-12 grid gap-10 lg:grid-cols-[1.2fr_1fr_1fr]">
    <div>
      <div class="flex items-center gap-3 mb-4">
        <LogoHG />
        <div>
          <p class="text-sm font-semibold text-white">HGuerra</p>
          <p class="text-sm text-slate-400">Soluciones digitales para operaciones y automatización</p>
        </div>
      </div>
      <p class="text-sm text-slate-400 max-w-md">
        Diseño productos y automatizaciones que conectan operación, datos y adopción real en campo y oficina.
      </p>
    </div>

    <div>
      <h2 class="text-sm font-semibold text-white mb-4">Rutas</h2>
      <ul class="space-y-3 text-sm text-slate-400">
        {footerLinks.map((link) => (
          <li>
            <a href={link.href} class="hover:text-blue-400 transition-colors">{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-semibold text-white mb-4">Contacto</h2>
      <ul class="space-y-3 text-sm text-slate-400">
        <li><a href={`mailto:${contactConfig.email}`} class="hover:text-blue-400 transition-colors">{contactConfig.email}</a></li>
        <li><a href={`https://wa.me/${contactConfig.whatsappNumber}`} class="hover:text-blue-400 transition-colors">{contactConfig.whatsappDisplay}</a></li>
        <li><a href={contactConfig.calendlyUrl} class="hover:text-blue-400 transition-colors">Calendly</a></li>
      </ul>
    </div>
  </div>
</footer>
