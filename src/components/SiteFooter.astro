---
import LogoHG from './LogoHG.astro';
import { CONTACT_PAGE_PATH, getWhatsAppHref } from '../data/contact';
import { footerLinks } from '../data/site';

const whatsappHref = getWhatsAppHref();
---

<footer class="border-t border-slate-800 bg-slate-950">
  <div class="max-w-7xl mx-auto px-6 py-12 grid gap-10 lg:grid-cols-[1.2fr_1fr_1fr]">
    <div>
      <div class="flex items-center gap-3 mb-4">
        <LogoHG />
        <div>
          <p class="text-sm font-semibold text-white">HGuerra</p>
          <p class="text-sm text-slate-400">Consultoría e implementación para operación y automatización</p>
        </div>
      </div>
      <p class="text-sm text-slate-400 max-w-md">
        Trabajo problemas operativos complejos hasta convertirlos en soluciones claras, útiles y adoptables para equipos reales.
      </p>
    </div>

    <div>
      <h2 class="text-sm font-semibold text-white mb-4">Rutas</h2>
      <ul class="space-y-3 text-sm text-slate-400">
        {footerLinks.map((link) => (
          <li>
            <a href={link.href} class="hover:text-blue-400 transition-colors">{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-semibold text-white mb-4">Contacto</h2>
      <ul class="space-y-3 text-sm text-slate-400">
        <li><a href={CONTACT_PAGE_PATH} class="hover:text-blue-400 transition-colors">Formulario</a></li>
        <li><a href={whatsappHref} class="hover:text-blue-400 transition-colors">WhatsApp</a></li>
      </ul>
    </div>
  </div>
</footer>
