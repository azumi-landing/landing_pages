---
import LogoHG from './LogoHG.astro';
import { CONTACT_PAGE_PATH } from '../data/contact';

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/gestion-de-operaciones-de-campo', label: 'Gestión de Operaciones de Campo' },
  { href: '/automatizacion-con-ia-agentica', label: 'Automatización con IA Agéntica' },
  { href: '/automatizacion-de-procesos', label: 'Automatización de Procesos' }
];
---

<nav class="sticky top-0 left-0 right-0 z-50 bg-slate-950/90 backdrop-blur-sm border-b border-slate-800/80">
  <div class="max-w-7xl mx-auto px-6 py-4">
    <div class="flex items-center justify-between gap-6">
      <LogoHG />
      <div class="hidden md:block flex-1">
        <p class="text-sm font-semibold text-white">HGuerra</p>
        <p class="text-xs text-slate-400">Consultoría aplicada para operación, producto y automatización</p>
      </div>

      <ul class="hidden xl:flex items-center gap-6 text-sm font-medium text-slate-300">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="hover:text-blue-400 transition-colors">
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <a
        href={CONTACT_PAGE_PATH}
        class="inline-flex items-center justify-center px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white text-sm font-semibold rounded-lg transition-colors whitespace-nowrap"
      >
        Contacto
      </a>
    </div>

    <ul class="xl:hidden flex flex-wrap gap-3 mt-4 text-sm font-medium text-slate-300">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="inline-flex px-3 py-2 rounded-full border border-white/10 bg-white/5 hover:bg-white/10 transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>
