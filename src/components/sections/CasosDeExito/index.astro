---
import { casosExito } from '../../../data/casos';
import { buildContactHref } from '../../../data/contact';
import CasoCard from '../../molecules/CasoCard.astro';

const fieldOpsContactHref = buildContactHref({
  service: 'gestion-operaciones-de-campo',
  originPath: '/gestion-de-operaciones-de-campo',
  originLabel: 'Gestión de Operaciones de Campo'
});
---

<section id="casos" class="py-24 px-6 bg-gradient-to-br from-slate-900 to-slate-800">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Casos de éxito reales
      </h2>
      <p class="text-xl text-slate-300 max-w-3xl mx-auto">
        Implementaciones que reducen errores de campo y entregan visibilidad real en sectores críticos
      </p>
    </div>
    
    <!-- Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {casosExito.map((caso) => (
        <CasoCard caso={caso} />
      ))}
    </div>
    
    <!-- CTA -->
    <div class="text-center mt-12">
      <a 
        href={fieldOpsContactHref}
        class="inline-block px-6 py-3 bg-gradient-to-r from-blue-500 to-blue-600 text-white font-semibold rounded-lg text-center transition-all duration-300 hover:from-blue-600 hover:to-blue-700 hover:-translate-y-0.5 hover:shadow-lg border border-blue-500/30"
      >
        ¿Tienes un desafío similar? Hablemos
      </a>
    </div>
  </div>
</section>
