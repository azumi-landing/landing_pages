---
import { stackItems } from '../../../data/stack';
import StackItem from '../../molecules/StackItem.astro';
---

<section id="stack" class="py-24 px-6 bg-gradient-to-br from-slate-900 to-slate-800">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Stack técnico
      </h2>
      <p class="text-xl text-slate-300 max-w-3xl mx-auto">
        Tecnologías modernas para soluciones escalables en la nube
      </p>
    </div>
    
    <!-- Accordion -->
    <div class="max-w-4xl mx-auto space-y-4" id="stack-accordion">
      {stackItems.map((item) => (
        <StackItem item={item} />
      ))}
    </div>
  </div>
</section>

<script>
  // Accordion chevron rotation
  const items = document.querySelectorAll('#stack-accordion details');
  items.forEach(item => {
    item.addEventListener('toggle', () => {
      const chevron = item.querySelector('.accordion-chevron');
      if (chevron) {
        (chevron as HTMLElement).style.transform = item.open ? 'rotate(180deg)' : 'rotate(0deg)';
      }
    });
  });
</script>
