---
import Icon from '../../atoms/Icon.astro';

const seguridadItems = [
  {
    title: 'Evidencia Inmutable',
    icon: 'fa-lock',
    description: 'Cada registro incluye timestamp automático, ubicación GPS, fotos obligatorias y firma digital. Historial versionado que no puede alterarse.',
    features: ['Timestamp no editable', 'GPS georreferenciado', 'Fotos con metadatos preservados', 'Firma digital del operario']
  },
  {
    title: 'Auditoría Completa',
    icon: 'fa-clipboard-check',
    description: 'Trazabilidad end-to-end desde asignación en web hasta cierre en campo. Reportes de auditoría generados en un clic.',
    features: ['Quién, cuándo, dónde, qué', 'Historial de cambios', 'Exportación en PDF/CSV', 'API para sistemas externos']
  },
  {
    title: 'Seguridad Cloud Enterprise',
    icon: 'fa-shield-alt',
    description: 'Arquitectura en Google Cloud Platform con certificaciones ISO 27001, SOC 2. Encriptación en tránsito y reposo.',
    features: ['ISO 27001 / SOC 2', 'Encriptación AES-256', 'IAM y RBAC', 'Auto-scaling seguro']
  },
  {
    title: 'Compliance Normativo',
    icon: 'fa-balance-scale',
    description: 'Datos listos para auditorías de calidad (ISO 9001), seguridad (OHSAS), y regulatorias sectoriales.',
    features: ['ISO 9001 / HACCP', 'OHSAS 18001', 'GDPR / Privacidad', 'Retención configurable']
  }
];

const badges = [
  { name: 'ISO 27001', icon: 'fa-certificate' },
  { name: 'SOC 2', icon: 'fa-check-circle' },
  { name: 'GDPR Ready', icon: 'fa-user-shield' },
  { name: 'Cloud Secure', icon: 'fa-cloud' }
];
---

<section id="seguridad" class="py-24 px-6 bg-[#F8FAFC]">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-[#1E293B] mb-4">
        Arquitectura segura, trazabilidad inmutable, compliance demostrable
      </h2>
      <p class="text-xl text-[#475569] max-w-3xl mx-auto">
        Cuando una auditoría externa revisa tu operación, necesitas evidencia sólida. 
        Nuestra plataforma está diseñada para que "pasar auditorías sin hallazgos" sea el estándar.
      </p>
    </div>

    <!-- Badges -->
    <div class="flex flex-wrap justify-center gap-4 mb-12">
      {badges.map((badge) => (
        <div class="flex items-center gap-2 px-4 py-2 bg-white rounded-full shadow-sm border border-slate-200">
          <Icon name={badge.icon} class="text-blue-600" />
          <span class="text-sm font-semibold text-[#1E293B]">{badge.name}</span>
        </div>
      ))}
    </div>

    <!-- Security Items Grid -->
    <div class="grid md:grid-cols-2 gap-6 mb-12">
      {seguridadItems.map((item) => (
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-200 hover:shadow-md transition-shadow">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center shrink-0">
              <Icon name={item.icon} size="lg" class="text-blue-600" />
            </div>
            <div>
              <h3 class="text-xl font-bold text-[#1E293B] mb-2">{item.title}</h3>
              <p class="text-[#475569] text-sm leading-relaxed">{item.description}</p>
            </div>
          </div>
          <div class="border-t border-slate-100 pt-4">
            <ul class="grid grid-cols-2 gap-2">
              {item.features.map((feature) => (
                <li class="flex items-center gap-2 text-sm text-[#475569]">
                  <Icon name="fa-check" class="text-green-500 text-xs" />
                  {feature}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <!-- Quote/Testimonial -->
    <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-200 rounded-2xl p-8">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-full bg-blue-500 flex items-center justify-center shrink-0">
          <Icon name="fa-quote-left" class="text-white" />
        </div>
        <div>
          <p class="text-lg text-[#1E293B] italic mb-4">
            "Nuestra última auditoría externa encontró cero hallazgos de trazabilidad. 
            Todo estaba documentado: quién hizo qué, cuándo, dónde, con fotos y GPS. 
            Lo que antes nos tomaba días de reconstrucción manual, ahora está disponible en minutos."
          </p>
          <p class="text-sm text-[#475569]">
            <strong class="text-[#1E293B]">— Gerente de Operaciones</strong>, Empresa de Energía
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
