---
import Icon from '../../atoms/Icon.astro';

const metricas = [
  {
    valor: '-60%',
    label: 'Errores de captura',
    impacto: 'En 3 semanas',
    icon: 'fa-check-double',
    descripcion: 'Validación en origen elimina reprocesos'
  },
  {
    valor: '100%',
    label: 'Trazabilidad',
    impacto: 'GPS + Timestamp + Fotos',
    icon: 'fa-map-marker-alt',
    descripcion: 'Auditorías sin hallazgos garantizadas'
  },
  {
    valor: 'De horas a minutos',
    label: 'Tiempo de respuesta',
    impacto: 'Órdenes automáticas',
    icon: 'fa-bolt',
    descripcion: 'Alarmas → Asignación sin intervención'
  },
  {
    valor: '100%',
    label: 'Visibilidad',
    impacto: 'Operaciones en tiempo real',
    icon: 'fa-eye',
    descripcion: 'Sin llamadas de seguimiento'
  },
  {
    valor: '-90%',
    label: 'Llamadas de supervisión',
    impacto: 'Dashboard en vivo',
    icon: 'fa-phone-slash',
    descripcion: 'Supervisores enfocados en análisis'
  },
  {
    valor: 'De días a minutos',
    label: 'Tiempos de auditoría',
    impacto: 'Evidencia inmutable',
    icon: 'fa-clipboard-check',
    descripcion: 'Reportes automáticos, sin reconstrucción'
  }
];
---

<section id="resultados" class="section-shell section-light">
  <div class="page-container">
    <div class="section-intro section-intro-center">
      <p class="section-eyebrow justify-center text-slate-500">Prueba de valor</p>
      <h2 class="section-title text-slate-950">
        Resultados y señales de valor en operación
      </h2>
      <p class="section-copy text-slate-600">
        Indicadores que hacen visible el cambio operativo cuando la captura, la ejecución y la auditoría quedan conectadas
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {metricas.map((metrica) => (
        <div class="surface-card p-6 transition-colors hover:shadow-[0_22px_55px_rgba(15,23,42,0.1)]">
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl bg-slate-950 flex items-center justify-center shrink-0">
              <Icon name={metrica.icon} size="lg" class="text-white" />
            </div>
            <div>
              <p class="text-3xl font-bold text-slate-950">{metrica.valor}</p>
              <p class="text-sm text-slate-700 font-medium">{metrica.label}</p>
            </div>
          </div>
          <div class="border-t border-slate-200 pt-4">
            <p class="text-sm text-slate-600 mb-1">
              <strong class="text-slate-950">{metrica.impacto}</strong>
            </p>
            <p class="text-xs text-slate-500">{metrica.descripcion}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="surface-soft p-8 text-center">
      <p class="text-lg text-slate-600 mb-2">
        <Icon name="fa-database" class="inline mr-2 text-blue-600" />
        <strong class="text-slate-950">+5,000,000 registros procesados</strong> en implementaciones reales
      </p>
      <p class="text-sm text-slate-500">
        +10 años de experiencia en operaciones de campo en sectores críticos
      </p>
    </div>
  </div>
</section>
