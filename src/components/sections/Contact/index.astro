---
import { contactConfig, formTopics } from '../../../data/contact';
import Button from '../../atoms/Button.astro';
---

<section id="contacto" class="py-24 px-6 bg-gradient-to-br from-slate-900 to-slate-800">
  <div class="max-w-7xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-12 items-start">
      <!-- Left: Info -->
      <div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
          ¿Listo para tener control total de tus operaciones de campo?
        </h2>
        <p class="text-xl text-slate-300 mb-8">
          Agenda una demo personalizada de 30 minutos. Veremos tu caso específico, mostraremos flujos relevantes para tu sector, y responderemos preguntas técnicas.
        </p>
        
        <div class="bg-gradient-to-r from-blue-500/20 to-purple-500/20 border border-blue-500/30 rounded-xl p-6 mb-8">
          <h3 class="text-lg font-semibold text-white mb-3">En la demo verás:</h3>
          <ul class="space-y-2 text-slate-300">
            <li class="flex items-center gap-2">
              <i class="fas fa-check text-green-400"></i>
              <span>La app móvil funcionando offline con tu flujo específico</span>
            </li>
            <li class="flex items-center gap-2">
              <i class="fas fa-check text-green-400"></i>
              <span>Dashboard en vivo con métricas de tu sector</span>
            </li>
            <li class="flex items-center gap-2">
              <i class="fas fa-check text-green-400"></i>
              <span>Auditoría completa con evidencia inmutable</span>
            </li>
            <li class="flex items-center gap-2">
              <i class="fas fa-check text-green-400"></i>
              <span>Proyección de ROI para tu operación</span>
            </li>
          </ul>
        </div>
        
        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-green-500/20 flex items-center justify-center">
              <i class="fab fa-whatsapp text-green-500 text-xl"></i>
            </div>
            <div>
              <p class="text-white font-medium">WhatsApp Directo</p>
              <a href={`https://wa.me/${contactConfig.whatsappNumber}`} class="text-slate-300 hover:text-blue-400 transition-colors">
                {contactConfig.whatsappDisplay}
              </a>
            </div>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-blue-500/20 flex items-center justify-center">
              <i class="fas fa-envelope text-blue-500 text-xl"></i>
            </div>
            <div>
              <p class="text-white font-medium">Email</p>
              <a href={`mailto:${contactConfig.email}`} class="text-slate-300 hover:text-blue-400 transition-colors">
                {contactConfig.email}
              </a>
            </div>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-purple-500/20 flex items-center justify-center">
              <i class="fas fa-calendar text-purple-500 text-xl"></i>
            </div>
            <div>
              <p class="text-white font-medium">Agenda una llamada</p>
              <a href={contactConfig.calendlyUrl} class="text-slate-300 hover:text-blue-400 transition-colors">
                15 min — Calendly
              </a>
            </div>
          </div>
        </div>
        
        <p class="text-slate-400 mt-8 text-sm">
          <i class="fas fa-clock mr-2"></i>
          Respondo en {contactConfig.responseTime} en horario laboral
        </p>
      </div>
      
      <!-- Right: Form -->
      <div class="card bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8">
        <h3 class="text-2xl font-bold text-white mb-6">Cuéntame de tu desafío</h3>
        
        <form action={`https://formsubmit.co/ajax/${contactConfig.email}`} method="POST" class="space-y-6" id="contact-form">
          <input type="hidden" name="_subject" value="Nuevo contacto - Landing Page" />
          <input type="hidden" name="_next" value={Astro.url} />
          <input type="hidden" name="_captcha" value="false" />
          
          <div>
            <label for="email" class="block text-sm font-medium text-slate-300 mb-2">Email *</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required 
              class="w-full px-4 py-3 bg-slate-800/50 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:outline-none focus:border-blue-500 transition-colors"
              placeholder="tu@empresa.com"
            />
          </div>
          
          <div>
            <label for="interes" class="block text-sm font-medium text-slate-300 mb-2">¿Qué necesitas? *</label>
            <select 
              id="interes" 
              name="interes" 
              required 
              class="w-full px-4 py-3 bg-slate-800/50 border border-slate-700 rounded-lg text-white focus:outline-none focus:border-blue-500 transition-colors"
            >
              {formTopics.map((topic) => (
                <option value={topic.value} disabled={topic.disabled} selected={topic.selected}>
                  {topic.label}
                </option>
              ))}
            </select>
          </div>
          
          <div>
            <label for="detalle" class="block text-sm font-medium text-slate-300 mb-2">Detalle breve</label>
            <textarea 
              id="detalle" 
              name="detalle" 
              rows={4} 
              class="w-full px-4 py-3 bg-slate-800/50 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:outline-none focus:border-blue-500 transition-colors resize-y"
              placeholder="¿Cuántos operarios? ¿Qué problemas tienes hoy? ¿Tienes sistema actual?"
            ></textarea>
          </div>
          
          <Button type="submit" variant="primary" size="lg" class="w-full">
            Enviar mensaje
          </Button>
          
          <div id="form-feedback" class="hidden text-center py-4 rounded-lg"></div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form');
  const feedback = document.getElementById('form-feedback');
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando...';
    }
    
    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form)
      });
      
      if (response.ok) {
        feedback!.className = 'block bg-green-500/20 text-green-400 border border-green-500/30 text-center py-4 rounded-lg';
        feedback!.textContent = '¡Mensaje enviado! Te contacto pronto.';
        form.reset();
      } else {
        throw new Error('Error al enviar');
      }
    } catch (error) {
      feedback!.className = 'block bg-red-500/20 text-red-400 border border-red-500/30 text-center py-4 rounded-lg';
      feedback!.textContent = 'Hubo un error. Intenta por WhatsApp o email.';
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enviar mensaje';
      }
    }
  });
</script>
