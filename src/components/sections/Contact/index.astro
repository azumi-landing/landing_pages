---
import {
  buildContactHref,
  contactConfig,
  getWhatsAppHref,
  getContactContextByPath
} from '../../../data/contact';
import { fieldOperationsTheme } from '../../../data/serviceThemes';
import Button from '../../atoms/Button.astro';
import type { ServiceLandingContactContent, ServiceLandingTheme } from '../../../types/serviceLanding';

interface Props {
  content?: ServiceLandingContactContent;
  theme?: ServiceLandingTheme;
}

const { content, theme = fieldOperationsTheme } = Astro.props;

const resolvedContent = {
  eyebrow: content?.eyebrow,
  title: content?.title ?? '¿Listo para aterrizar tu operación en un flujo más controlado?',
  description:
    content?.description ??
    'Centralicé el contacto en un único formulario para responder con mejor contexto. Si vienes desde esta landing, el tema ya queda marcado como gestión de operaciones de campo.',
  detailsTitle: content?.detailsTitle ?? 'En la primera conversación revisamos:',
  detailsItems: content?.detailsItems ?? [
    'Qué flujo de campo estás intentando ordenar o digitalizar',
    'Qué evidencias, validaciones o integraciones son críticas para tu operación',
    'Si el siguiente paso correcto es demo, diagnóstico o alcance inicial'
  ],
  source: content?.source ?? 'gestion-de-operaciones-de-campo'
};

const originPath = resolvedContent.source.startsWith('/') ? resolvedContent.source : `/${resolvedContent.source}`;
const context = getContactContextByPath(originPath);
const contactHref = buildContactHref({
  service: context.service,
  originPath,
  originLabel: context.originLabel
});
const whatsappHref = getWhatsAppHref();
const themeVars = `--service-accent: ${theme.accent}; --service-accent-alt: ${theme.accentAlt}; --service-accent-soft: ${theme.accentSoft}; --service-accent-glow: ${theme.accentGlow}; --service-accent-shadow: ${theme.accentShadow};`;
---

<section id="contacto" class="service-contact py-24 px-6 bg-gradient-to-br from-slate-900 to-slate-800" style={themeVars}>
  <div class="max-w-7xl mx-auto">
    <div class="grid lg:grid-cols-[1.15fr_0.85fr] gap-12 items-start">
      <div>
        {resolvedContent.eyebrow && (
          <span class="service-contact-pill inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold mb-5">
            <i class={`fas ${theme.badgeIcon}`}></i>
            {resolvedContent.eyebrow}
          </span>
        )}
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
          {resolvedContent.title}
        </h2>
        <p class="text-xl text-slate-300 mb-8">
          {resolvedContent.description}
        </p>

        <div class="service-context-chip inline-flex items-center gap-2 rounded-full px-4 py-2 mb-8 text-xs font-semibold uppercase tracking-[0.24em] text-white/80">
          <span class="service-context-dot h-2.5 w-2.5 rounded-full"></span>
          {theme.sectionMark}
        </div>

        <div class="service-contact-panel rounded-xl p-6 mb-8">
          <h3 class="text-lg font-semibold text-white mb-3">{resolvedContent.detailsTitle}</h3>
          <ul class="space-y-2 text-slate-300">
            {resolvedContent.detailsItems.map((item) => (
              <li class="flex items-center gap-2">
                <i class="fas fa-check service-contact-check"></i>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="flex flex-col sm:flex-row gap-4">
          <Button href={contactHref} variant="primary" size="lg" class="service-contact-submit">
            Abrir formulario
          </Button>
          <Button href={contactConfig.calendlyUrl} variant="secondary" size="lg">
            <i class="fas fa-calendar-alt mr-2"></i>
            Agendar llamada
          </Button>
        </div>
      </div>

      <aside class="service-contact-panel rounded-2xl p-8">
        <h3 class="text-2xl font-bold text-white mb-6">Canales directos</h3>
        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-green-500/20 flex items-center justify-center">
              <i class="fab fa-whatsapp text-green-500 text-xl"></i>
            </div>
            <div>
              <p class="text-white font-medium">WhatsApp</p>
              <a href={whatsappHref} class="service-contact-link text-slate-300 transition-colors">
                Abrir conversación
              </a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-blue-500/20 flex items-center justify-center">
              <i class="fas fa-calendar-alt text-blue-500 text-xl"></i>
            </div>
            <div>
              <p class="text-white font-medium">Agenda una llamada</p>
              <a href={contactConfig.calendlyUrl} class="service-contact-link text-slate-300 transition-colors">
                Coordinar por Calendly
              </a>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-purple-500/20 flex items-center justify-center">
              <i class="fas fa-clock text-purple-400 text-xl"></i>
            </div>
            <div>
              <p class="text-white font-medium">Tiempo de respuesta</p>
              <p class="text-slate-300">Normalmente {contactConfig.responseTime}</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .service-contact-pill {
    border: 1px solid var(--service-accent-soft);
    background: linear-gradient(135deg, var(--service-accent-soft), rgba(255, 255, 255, 0.04));
    color: var(--service-accent);
  }

  .service-context-chip {
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.06), var(--service-accent-soft));
  }

  .service-context-dot {
    background: linear-gradient(135deg, var(--service-accent), var(--service-accent-alt));
    box-shadow: 0 0 18px -4px var(--service-accent-shadow);
  }

  .service-contact-panel {
    border: 1px solid var(--service-accent-soft);
    background: linear-gradient(135deg, var(--service-accent-soft), rgba(15, 23, 42, 0.34));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .service-contact-check {
    color: var(--service-accent-alt);
  }

  .service-contact-link:hover {
    color: var(--service-accent);
  }

  .service-contact-submit {
    border: 1px solid transparent !important;
    background: linear-gradient(135deg, var(--service-accent), var(--service-accent-alt)) !important;
    box-shadow: 0 18px 40px -28px var(--service-accent-shadow);
  }

  .service-contact-submit:hover {
    transform: translateY(-1px);
    box-shadow: 0 24px 52px -30px var(--service-accent-shadow);
  }
</style>
