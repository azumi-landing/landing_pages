---
import { contactConfig, formTopics } from '../../../data/contact';
import { fieldOperationsTheme } from '../../../data/serviceThemes';
import Button from '../../atoms/Button.astro';
import type { ServiceLandingContactContent, ServiceLandingTheme } from '../../../types/serviceLanding';

interface Props {
  content?: ServiceLandingContactContent;
  theme?: ServiceLandingTheme;
}

const { content, theme = fieldOperationsTheme } = Astro.props;

const whatsappHref = `https://wa.me/${contactConfig.whatsappNumber}?text=${encodeURIComponent(contactConfig.whatsappMessage)}`;
const themeVars = `--service-accent: ${theme.accent}; --service-accent-alt: ${theme.accentAlt}; --service-accent-soft: ${theme.accentSoft}; --service-accent-glow: ${theme.accentGlow}; --service-accent-shadow: ${theme.accentShadow};`;

const resolvedContent = {
  eyebrow: content?.eyebrow,
  title: content?.title ?? '¿Listo para tener control total de tus operaciones de campo?',
  description:
    content?.description ??
    'Agenda una demo personalizada de 30 minutos. Veremos tu caso específico, mostraremos flujos relevantes para tu sector, y responderemos preguntas técnicas.',
  detailsTitle: content?.detailsTitle ?? 'En la demo verás:',
  detailsItems: content?.detailsItems ?? [
    'La app móvil funcionando offline con tu flujo específico',
    'Dashboard en vivo con métricas de tu sector',
    'Auditoría completa con evidencia inmutable',
    'Proyección de ROI para tu operación'
  ],
  topics: content?.topics ?? formTopics,
  formTitle: content?.formTitle ?? 'Cuéntame de tu desafío',
  detailPlaceholder:
    content?.detailPlaceholder ?? '¿Cuántos operarios? ¿Qué problemas tienes hoy? ¿Tienes sistema actual?',
  source: content?.source ?? 'gestion-de-operaciones-de-campo'
};
---

<section id="contacto" class="service-contact py-24 px-6 bg-gradient-to-br from-slate-900 to-slate-800" style={themeVars}>
  <div class="max-w-7xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-12 items-start">
      <!-- Left: Info -->
      <div>
        {resolvedContent.eyebrow && (
          <span class="service-contact-pill inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold mb-5">
            <i class={`fas ${theme.badgeIcon}`}></i>
            {resolvedContent.eyebrow}
          </span>
        )}
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
          {resolvedContent.title}
        </h2>
        <p class="text-xl text-slate-300 mb-8">
          {resolvedContent.description}
        </p>

        <div class="service-context-chip inline-flex items-center gap-2 rounded-full px-4 py-2 mb-8 text-xs font-semibold uppercase tracking-[0.24em] text-white/80">
          <span class="service-context-dot h-2.5 w-2.5 rounded-full"></span>
          {theme.sectionMark}
        </div>
        
        <div class="service-contact-panel rounded-xl p-6 mb-8">
          <h3 class="text-lg font-semibold text-white mb-3">{resolvedContent.detailsTitle}</h3>
          <ul class="space-y-2 text-slate-300">
            {resolvedContent.detailsItems.map((item) => (
              <li class="flex items-center gap-2">
                <i class="fas fa-check service-contact-check"></i>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        
        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-green-500/20 flex items-center justify-center">
              <i class="fab fa-whatsapp text-green-500 text-xl"></i>
            </div>
            <div>
              <p class="text-white font-medium">WhatsApp Directo</p>
              <a href={whatsappHref} class="service-contact-link text-slate-300 transition-colors">
                {contactConfig.whatsappDisplay}
              </a>
            </div>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-blue-500/20 flex items-center justify-center">
              <i class="fas fa-envelope text-blue-500 text-xl"></i>
            </div>
            <div>
              <p class="text-white font-medium">Email</p>
              <a href={`mailto:${contactConfig.email}`} class="service-contact-link text-slate-300 transition-colors">
                {contactConfig.email}
              </a>
            </div>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-purple-500/20 flex items-center justify-center">
              <i class="fas fa-calendar text-purple-500 text-xl"></i>
            </div>
            <div>
              <p class="text-white font-medium">Agenda una llamada</p>
              <a href={contactConfig.calendlyUrl} class="service-contact-link text-slate-300 transition-colors">
                15 min — Calendly
              </a>
            </div>
          </div>
        </div>
        
        <p class="text-slate-400 mt-8 text-sm">
          <i class="fas fa-clock mr-2"></i>
          Respondo en {contactConfig.responseTime} en horario laboral
        </p>
      </div>
      
      <!-- Right: Form -->
      <div class="service-contact-form card bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8">
        <h3 class="text-2xl font-bold text-white mb-6">{resolvedContent.formTitle}</h3>
        
        <form class="space-y-6" id="service-contact-form" data-source={resolvedContent.source}>
          <div>
            <label for="email" class="block text-sm font-medium text-slate-300 mb-2">Email *</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required 
              class="service-contact-input w-full px-4 py-3 bg-slate-800/50 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:outline-none transition-colors"
              placeholder="tu@empresa.com"
            />
          </div>
          
          <div>
            <label for="interes" class="block text-sm font-medium text-slate-300 mb-2">¿Qué necesitas? *</label>
            <select 
              id="interes" 
              name="interes" 
              required 
              class="service-contact-input w-full px-4 py-3 bg-slate-800/50 border border-slate-700 rounded-lg text-white focus:outline-none transition-colors"
            >
              {resolvedContent.topics.map((topic) => (
                <option value={topic.value} disabled={topic.disabled} selected={topic.selected}>
                  {topic.label}
                </option>
              ))}
            </select>
          </div>
          
          <div>
            <label for="detalle" class="block text-sm font-medium text-slate-300 mb-2">Detalle breve</label>
            <textarea 
              id="detalle" 
              name="detalle" 
              rows={4} 
              class="service-contact-input w-full px-4 py-3 bg-slate-800/50 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:outline-none transition-colors resize-y"
              placeholder={resolvedContent.detailPlaceholder}
            ></textarea>
          </div>
          
          <Button type="submit" variant="primary" size="lg" class="service-contact-submit w-full">
            Enviar mensaje
          </Button>
          
          <div id="form-feedback" class="hidden text-center py-4 rounded-lg"></div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('service-contact-form');
  const feedback = document.getElementById('form-feedback');
  const emailjsConfig = {
    serviceId: import.meta.env.PUBLIC_EMAILJS_SERVICE_ID || '',
    templateId: import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID || '',
    publicKey: import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY || ''
  };

  const setFeedback = (type, message) => {
    if (!(feedback instanceof HTMLElement)) return;

    feedback.className =
      type === 'success'
        ? 'block bg-green-500/20 text-green-400 border border-green-500/30 text-center py-4 rounded-lg'
        : 'block bg-red-500/20 text-red-400 border border-red-500/30 text-center py-4 rounded-lg';
    feedback.textContent = message;
  };

  if (form instanceof HTMLFormElement) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const submitBtn = form.querySelector('button[type="submit"]');
      const formData = new FormData(form);

      if (!emailjsConfig.serviceId || !emailjsConfig.templateId || !emailjsConfig.publicKey) {
        setFeedback('error', 'El formulario aún no está configurado. Usa WhatsApp o email mientras activamos el envío.');
        return;
      }

      if (submitBtn instanceof HTMLButtonElement) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Enviando...';
      }

      try {
        const response = await fetch('https://api.emailjs.com/api/v1.0/email/send', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            service_id: emailjsConfig.serviceId,
            template_id: emailjsConfig.templateId,
            user_id: emailjsConfig.publicKey,
            template_params: {
              reply_to: formData.get('email'),
              interest: formData.get('interes'),
              detail: formData.get('detalle'),
              source: form.dataset.source || 'service-landing',
              to_email: 'hola@hguerra.com'
            }
          })
        });

        if (!response.ok) {
          throw new Error('EmailJS request failed');
        }

        form.reset();
        setFeedback('success', '¡Mensaje enviado! Te contacto pronto.');
      } catch (error) {
        setFeedback('error', 'Hubo un error. Intenta por WhatsApp o email.');
      } finally {
        if (submitBtn instanceof HTMLButtonElement) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Enviar mensaje';
        }
      }
    });
  }
</script>

<style>
  .service-contact-pill {
    border: 1px solid var(--service-accent-soft);
    background: linear-gradient(135deg, var(--service-accent-soft), rgba(255, 255, 255, 0.04));
    color: var(--service-accent);
  }

  .service-context-chip {
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.06), var(--service-accent-soft));
  }

  .service-context-dot {
    background: linear-gradient(135deg, var(--service-accent), var(--service-accent-alt));
    box-shadow: 0 0 18px -4px var(--service-accent-shadow);
  }

  .service-contact-panel {
    border: 1px solid var(--service-accent-soft);
    background: linear-gradient(135deg, var(--service-accent-soft), rgba(15, 23, 42, 0.34));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .service-contact-check {
    color: var(--service-accent-alt);
  }

  .service-contact-link:hover {
    color: var(--service-accent);
  }

  .service-contact-form {
    position: relative;
    overflow: hidden;
  }

  .service-contact-form::before {
    content: '';
    position: absolute;
    inset: 0 auto auto 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, var(--service-accent), transparent 72%);
  }

  .service-contact-input:focus {
    border-color: var(--service-accent);
    box-shadow: 0 0 0 3px var(--service-accent-soft);
  }

  .service-contact-submit {
    border: 1px solid transparent !important;
    background: linear-gradient(135deg, var(--service-accent), var(--service-accent-alt)) !important;
    box-shadow: 0 18px 40px -28px var(--service-accent-shadow);
  }

  .service-contact-submit:hover {
    transform: translateY(-1px);
    box-shadow: 0 24px 52px -30px var(--service-accent-shadow);
  }
</style>
