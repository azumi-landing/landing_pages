---
import Button from '../atoms/Button.astro';
import {
  formTopics,
  getContactServiceLabel,
  isValidContactService
} from '../../data/contact';

interface Props {
  defaultService?: string | null;
  originPath?: string | null;
  originLabel?: string | null;
  tone?: 'dark' | 'light';
}

const {
  defaultService = '',
  originPath = '',
  originLabel = '',
  tone = 'dark'
} = Astro.props;

const normalizedService = isValidContactService(defaultService) ? defaultService : '';
const resolvedOriginLabel = originLabel || getContactServiceLabel(normalizedService);
const isLight = tone === 'light';
const labelClass = isLight ? 'text-slate-700' : 'text-slate-300';
const inputClass = isLight
  ? 'bg-white border border-slate-200 text-slate-900 placeholder-slate-400 focus:border-slate-950'
  : 'bg-slate-800/50 border border-slate-700 text-white placeholder-slate-500 focus:border-blue-500';
const legalTextClass = isLight ? 'text-slate-500' : 'text-slate-400';
const legalLinkClass = isLight ? 'text-slate-950 hover:text-slate-700' : 'text-blue-300 hover:text-blue-200';
---

<form
  class="space-y-6"
  data-emailjs-form
  data-emailjs-service-id={import.meta.env.PUBLIC_EMAILJS_SERVICE_ID ?? ''}
  data-emailjs-template-id={import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID ?? ''}
  data-emailjs-public-key={import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY ?? ''}
>
  <input type="hidden" name="origin_path" value={originPath} />
  <input type="hidden" name="origin_label" value={resolvedOriginLabel} />
  <input type="hidden" name="page_url" value={Astro.url.pathname} />
  <input type="hidden" name="reply_to" value="" />
  <input type="hidden" name="from_email" value="" />
  <input type="hidden" name="from_name" value="" />
  <input type="hidden" name="name" value="" />
  <input type="hidden" name="service" value={normalizedService} />
  <input type="hidden" name="service_label" value={normalizedService ? getContactServiceLabel(normalizedService) : ''} />
  <input type="hidden" name="subject" value="" />
  <input type="hidden" name="message" value="" />
  <input type="hidden" name="submitted_at" value="" />

  <div>
    <label for="contact-email" class={`block text-sm font-medium mb-2 ${labelClass}`}>Email *</label>
    <input
      type="email"
      id="contact-email"
      name="email"
      required
      class={`w-full px-4 py-3 rounded-2xl focus:outline-none transition-colors ${inputClass}`}
      placeholder="tu@empresa.com"
      autocomplete="email"
    />
  </div>

  <div>
    <label for="contact-service" class={`block text-sm font-medium mb-2 ${labelClass}`}>¿Qué necesitas? *</label>
    <select
      id="contact-service"
      name="interes"
      required
      class={`w-full px-4 py-3 rounded-2xl focus:outline-none transition-colors ${inputClass}`}
    >
      {formTopics.map((topic) => (
        <option
          value={topic.value}
          disabled={topic.disabled}
          selected={topic.value === normalizedService || (!normalizedService && topic.value === '')}
        >
          {topic.label}
        </option>
      ))}
    </select>
  </div>

  <div>
    <label for="contact-detail" class={`block text-sm font-medium mb-2 ${labelClass}`}>Detalle breve *</label>
    <textarea
      id="contact-detail"
      name="detalle"
      rows={5}
      required
      class={`w-full px-4 py-3 rounded-2xl focus:outline-none transition-colors resize-y ${inputClass}`}
      placeholder="¿Qué proceso quieres mejorar? ¿Qué equipo usa hoy el flujo? ¿Qué sistemas ya existen?"
    ></textarea>
  </div>

  <Button type="submit" variant="primary" size="lg" class="w-full justify-center">
    Enviar mensaje
  </Button>

  <div data-form-feedback class="hidden text-center py-4 rounded-lg text-sm"></div>

  <p class={`text-xs leading-relaxed ${legalTextClass}`}>
    Al enviar este formulario aceptas el tratamiento básico de tus datos para responder tu consulta.
    Puedes revisar la
    <a href="/privacidad" class={`transition-colors ${legalLinkClass}`}>política de privacidad</a>
    y los
    <a href="/terminos" class={`transition-colors ${legalLinkClass}`}>términos de uso</a>.
  </p>
</form>

<script>
  import emailjs, { EmailJSResponseStatus } from '@emailjs/browser';

  const contactForms = document.querySelectorAll('[data-emailjs-form]');

  contactForms.forEach((form) => {
    if (!(form instanceof HTMLFormElement) || form.dataset.bound === 'true') {
      return;
    }

    form.dataset.bound = 'true';

    const feedback = form.querySelector('[data-form-feedback]');
    const submitBtn = form.querySelector('button[type="submit"]');
    const emailField = form.querySelector('#contact-email');
    const serviceField = form.querySelector('#contact-service');
    const detailField = form.querySelector('#contact-detail');
    const originPathField = form.querySelector('input[name="origin_path"]');
    const originLabelField = form.querySelector('input[name="origin_label"]');
    const pageUrlField = form.querySelector('input[name="page_url"]');

    const setFeedback = (type, message) => {
      if (!(feedback instanceof HTMLElement)) {
        return;
      }

      const baseClasses = 'block text-center py-4 rounded-lg text-sm border';
      const toneClasses = {
        success: 'bg-green-500/20 text-green-400 border-green-500/30',
        error: 'bg-red-500/20 text-red-400 border-red-500/30'
      };

      feedback.className = `${baseClasses} ${toneClasses[type] ?? toneClasses.error}`;
      feedback.textContent = message;
    };

    const setHiddenValue = (name, value) => {
      const field = form.querySelector(`input[name="${name}"]`);
      if (field instanceof HTMLInputElement) {
        field.value = value;
      }
    };

    const syncEmailJsFields = () => {
      const email = emailField instanceof HTMLInputElement ? emailField.value.trim() : '';
      const selectedOption = serviceField instanceof HTMLSelectElement
        ? serviceField.selectedOptions[0] ?? null
        : null;
      const serviceValue = serviceField instanceof HTMLSelectElement ? serviceField.value : '';
      const serviceLabel = selectedOption?.textContent?.trim() ?? '';
      const detail = detailField instanceof HTMLTextAreaElement ? detailField.value.trim() : '';
      const originPathValue = originPathField instanceof HTMLInputElement
        ? originPathField.value.trim()
        : '';
      const originLabelValue = originLabelField instanceof HTMLInputElement
        ? originLabelField.value.trim()
        : '';
      const pageUrlValue = pageUrlField instanceof HTMLInputElement
        ? pageUrlField.value.trim()
        : '';

      const messageLines = [
        `Interes: ${serviceLabel || serviceValue || 'No especificado'}`,
        `Email: ${email || 'No especificado'}`,
        `Origen: ${originLabelValue || originPathValue || 'No especificado'}`,
        '',
        detail || 'Sin detalle adicional.',
        '',
        `Pagina: ${pageUrlValue || 'No especificada'}`
      ];

      setHiddenValue('reply_to', email);
      setHiddenValue('from_email', email);
      setHiddenValue('from_name', email || serviceLabel || 'Contacto web');
      setHiddenValue('name', email || 'Contacto web');
      setHiddenValue('service', serviceValue);
      setHiddenValue('service_label', serviceLabel);
      setHiddenValue('subject', `Nuevo contacto web | ${serviceLabel || 'Consulta general'}`);
      setHiddenValue('message', messageLines.join('\n'));
      setHiddenValue('submitted_at', new Date().toISOString());
    };

    syncEmailJsFields();

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const serviceId = form.dataset.emailjsServiceId?.trim();
      const templateId = form.dataset.emailjsTemplateId?.trim();
      const publicKey = form.dataset.emailjsPublicKey?.trim();

      if (!(submitBtn instanceof HTMLButtonElement)) {
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Enviando...';

      if (pageUrlField instanceof HTMLInputElement) {
        pageUrlField.value = window.location.href;
      }

      syncEmailJsFields();

      try {
        if (!serviceId || !templateId || !publicKey) {
          throw new Error('EmailJS no está configurado');
        }

        await emailjs.sendForm(serviceId, templateId, form, { publicKey });

        setFeedback('success', 'Mensaje enviado. Te responderé pronto.');
        form.reset();

        if (serviceField instanceof HTMLSelectElement) {
          const defaultValue = serviceField.querySelector('option[selected]')?.getAttribute('value') ?? '';
          serviceField.value = defaultValue;
        }

        if (originPathField instanceof HTMLInputElement) {
          originPathField.value = originPathField.defaultValue;
        }

        if (originLabelField instanceof HTMLInputElement) {
          originLabelField.value = originLabelField.defaultValue;
        }

        if (pageUrlField instanceof HTMLInputElement) {
          pageUrlField.value = pageUrlField.defaultValue;
        }

        syncEmailJsFields();
      } catch (error) {
        console.error('EmailJS submit failed', error);

        if (error instanceof EmailJSResponseStatus && error.status === 429) {
          setFeedback('error', 'El formulario recibió demasiados intentos seguidos. Espera unos segundos y vuelve a intentarlo.');
          return;
        }

        setFeedback('error', 'No pude enviar el mensaje. Escríbeme por WhatsApp mientras reviso el formulario.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Enviar mensaje';
      }
    });
  });
</script>
