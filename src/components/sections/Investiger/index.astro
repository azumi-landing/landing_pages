---
import { areasEspecializacion } from '../../../data/investigacion';
import FeatureCard from '../../molecules/FeatureCard.astro';
---

<section id="investigacion" class="py-24 px-6 bg-gradient-to-br from-slate-900 to-slate-800">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        ¿Por qué <em>investiguer</em>?
      </h2>
      <p class="text-xl text-slate-300 max-w-3xl mx-auto">
        <em>Investigar</em> + <em>Engineer</em>: Diseño modelos que reducen pérdidas y automatizan operaciones críticas, 
        con énfasis en entregar decisiones accionables en tiempo real.
      </p>
    </div>
    
    <!-- Cards - Horizontal Scroll -->
    <div class="relative">
      <div class="flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide" id="investigacion-carousel">
        {areasEspecializacion.map((area) => (
          <div class="snap-start shrink-0">
            <FeatureCard area={area} />
          </div>
        ))}
      </div>
      
      <!-- Navigation Dots -->
      <div class="flex justify-center gap-2 mt-6" id="investigacion-dots">
        {areasEspecializacion.map((_, i) => (
          <button 
            class="w-3 h-3 rounded-full bg-slate-600 transition-colors hover:bg-blue-500"
            data-index={i}
            aria-label={`Ir a área ${i + 1}`}
          />
        ))}
      </div>
    </div>
    
    <!-- CTA -->
    <div class="text-center mt-12">
      <a 
        href="#contacto" 
        class="inline-block px-6 py-3 bg-gradient-to-r from-blue-500 to-blue-600 text-white font-semibold rounded-lg text-center transition-all duration-300 hover:from-blue-600 hover:to-blue-700 hover:-translate-y-0.5 hover:shadow-lg border border-blue-500/30"
      >
        Explorar aplicación en tu operación
      </a>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  const carousel = document.getElementById('investigacion-carousel');
  const dots = document.querySelectorAll('#investigacion-dots button');
  
  if (carousel && dots.length > 0) {
    // Click on dots
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        const cardWidth = carousel.querySelector('.snap-start')?.getBoundingClientRect().width || 300;
        carousel.scrollTo({ left: index * (cardWidth + 24), behavior: 'smooth' });
      });
    });
    
    // Update active dot on scroll
    carousel.addEventListener('scroll', () => {
      const cardWidth = carousel.querySelector('.snap-start')?.getBoundingClientRect().width || 300;
      const activeIndex = Math.round(carousel.scrollLeft / (cardWidth + 24));
      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-blue-500', i === activeIndex);
        dot.classList.toggle('bg-slate-600', i !== activeIndex);
      });
    });
    
    // Set initial active dot
    dots[0].classList.add('bg-blue-500');
    dots[0].classList.remove('bg-slate-600');
  }
</script>
