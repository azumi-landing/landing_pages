---
import { servicios } from '../../../data/servicios';
import ServiceCard from '../../molecules/ServiceCard.astro';
---

<section id="servicios" class="section-shell section-muted">
  <div class="page-container">
    <div class="section-intro section-intro-center">
      <p class="section-eyebrow justify-center text-slate-500">Capacidades</p>
      <h2 class="section-title text-slate-950">
        Qué incluye esta solución
      </h2>
      <p class="section-copy text-slate-600">
        Capacidades que combinan captura en campo, control operativo y trazabilidad para que la ejecución deje de depender del seguimiento manual
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {servicios.map((servicio) => (
        <ServiceCard servicio={servicio} />
      ))}
    </div>
  </div>
</section>
