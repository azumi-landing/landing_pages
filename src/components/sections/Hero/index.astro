---
import Button from '../atoms/Button.astro';
---

<section id="inicio" class="relative min-h-screen bg-gradient-to-br from-[#0F172A] to-[#1E293B] text-white overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.15) 1px, transparent 0); background-size: 40px 40px;"></div>
  </div>
  
  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 pt-24 pb-16 min-h-screen flex flex-col justify-center">
    <div class="max-w-4xl">
      <!-- Badge -->
      <span class="inline-block px-4 py-2 bg-blue-500/20 text-blue-300 text-sm font-semibold rounded-full border border-blue-500/30 mb-6">
        ✓ App Móvil + Dashboard + Auditoría incluidos
      </span>
      
      <!-- Title -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
        Plataforma de gestión de operaciones de campo con app móvil
      </h1>
      
      <!-- Subtitle -->
      <p class="text-xl md:text-2xl text-slate-300 mb-8 leading-relaxed max-w-3xl">
        Gestión de campo conectada: app móvil con formularios, fotos y GPS, integrada a dashboard web para supervisores. 
        <span class="bg-gradient-to-r from-blue-400 to-cyan-400 bg-clip-text text-transparent font-semibold">Todo funciona offline.</span>
      </p>
      
      <!-- Benefits -->
      <div class="grid sm:grid-cols-3 gap-4 mb-10">
        <div class="flex items-center gap-3">
          <span class="text-green-400 text-xl">↓</span>
          <span class="text-slate-300">-60% errores de campo</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-green-400 text-xl">↓</span>
          <span class="text-slate-300">90% menos llamadas de seguimiento</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-green-400 text-xl">✓</span>
          <span class="text-slate-300">Auditoría completa con GPS y fotos</span>
        </div>
      </div>
      
      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 mb-12">
        <a 
          href="#contacto" 
          class="px-8 py-4 bg-gradient-to-r from-blue-500 to-blue-600 text-white font-bold rounded-xl text-lg text-center transition-all duration-300 hover:from-blue-600 hover:to-blue-700 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-blue-500/25 border border-blue-500/30"
        >
          Ver demo de tu operación
        </a>
        <a 
          href="#como-funciona" 
          class="px-8 py-4 bg-white/10 hover:bg-white/20 text-white font-bold rounded-xl text-lg text-center transition-all duration-300 border border-white/20"
        >
          Cómo funciona
        </a>
      </div>
      
      <!-- Metrics -->
      <div class="flex flex-wrap gap-8 text-center">
        <div>
          <p class="text-3xl font-bold text-blue-400">10+</p>
          <p class="text-sm text-slate-400">años en operaciones de campo</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-blue-400">5M+</p>
          <p class="text-sm text-slate-400">registros procesados</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-blue-400">-60%</p>
          <p class="text-sm text-slate-400">errores promedio</p>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <i class="fas fa-chevron-down text-slate-400 text-2xl"></i>
  </div>
</section>
