---
import {
  buildContactHref,
  contactConfig,
  getContactContextByPath
} from '../../data/contact';

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  ctaHref?: string;
  ctaLabel?: string;
  service?: string;
  originPath?: string;
  originLabel?: string;
}

const {
  eyebrow = 'Conversación inicial',
  title = '¿Quieres definir la mejor línea de servicio para tu operación?',
  description = 'Revisamos tu contexto, priorizamos la ruta correcta y aterrizamos un alcance inicial sin vender una solución genérica.',
  ctaHref,
  ctaLabel = 'Abrir formulario unificado',
  service,
  originPath = '/',
  originLabel
} = Astro.props;

const defaultContext = getContactContextByPath(originPath);
const resolvedCtaHref = ctaHref ?? buildContactHref({
  service: service ?? defaultContext.service,
  originPath,
  originLabel: originLabel ?? defaultContext.originLabel
});
---

<section id="contacto-general" class="py-24 px-6 bg-gradient-to-br from-slate-900 to-slate-800">
  <div class="max-w-6xl mx-auto rounded-3xl border border-blue-500/20 bg-gradient-to-r from-blue-500/15 to-cyan-500/10 p-8 md:p-12">
    <div class="grid gap-8 lg:grid-cols-[1.4fr_1fr] items-center">
      <div>
        <span class="inline-block px-4 py-2 rounded-full border border-blue-500/30 bg-blue-500/10 text-sm font-semibold text-blue-300 mb-5">
          {eyebrow}
        </span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          {title}
        </h2>
        <p class="text-lg text-slate-300 max-w-2xl">
          {description}
        </p>
      </div>

      <div class="space-y-4">
        <a
          href={resolvedCtaHref}
          class="flex items-center justify-between rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-white hover:bg-white/10 transition-colors"
        >
          <span>{ctaLabel}</span>
          <i class="fas fa-paper-plane text-blue-400"></i>
        </a>
        <a
          href={contactConfig.calendlyUrl}
          class="flex items-center justify-between rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-white hover:bg-white/10 transition-colors"
        >
          <span>Agendar llamada</span>
          <i class="fas fa-calendar-alt text-blue-400"></i>
        </a>
        <a
          href={`mailto:${contactConfig.email}`}
          class="flex items-center justify-between rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-white hover:bg-white/10 transition-colors"
        >
          <span>{contactConfig.email}</span>
          <i class="fas fa-envelope text-blue-400"></i>
        </a>
        <a
          href={`https://wa.me/${contactConfig.whatsappNumber}`}
          class="flex items-center justify-between rounded-2xl border border-white/10 bg-white/5 px-5 py-4 text-white hover:bg-white/10 transition-colors"
        >
          <span>{contactConfig.whatsappDisplay}</span>
          <i class="fab fa-whatsapp text-green-400"></i>
        </a>
      </div>
    </div>
  </div>
</section>
