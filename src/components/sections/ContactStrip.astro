---
import {
  buildContactHref,
  getWhatsAppHref,
  getContactContextByPath
} from '../../data/contact';

interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  ctaHref?: string;
  ctaLabel?: string;
  service?: string;
  originPath?: string;
  originLabel?: string;
}

const {
  eyebrow = 'Conversación inicial',
  title = '¿Quieres definir la mejor línea de servicio para tu operación?',
  description = 'Revisamos tu contexto, priorizamos la ruta correcta y aterrizamos un alcance inicial sin vender una solución genérica.',
  ctaHref,
  ctaLabel = 'Abrir formulario',
  service,
  originPath = '/',
  originLabel
} = Astro.props;

const defaultContext = getContactContextByPath(originPath);
const resolvedCtaHref = ctaHref ?? buildContactHref({
  service: service ?? defaultContext.service,
  originPath,
  originLabel: originLabel ?? defaultContext.originLabel
});
const whatsappHref = getWhatsAppHref();
---

<section id="contacto-general" class="section-shell section-dark">
  <div class="page-container-wide cta-band p-8 md:p-12">
    <div class="grid gap-8 lg:grid-cols-[1.25fr_0.75fr] items-center">
      <div>
        <span class="eyebrow-pill eyebrow-pill-dark mb-5">
          {eyebrow}
        </span>
        <h2 class="section-title text-white max-w-2xl">
          {title}
        </h2>
        <p class="section-copy text-slate-300 max-w-2xl">
          {description}
        </p>
      </div>

      <div class="space-y-4">
        <a
          href={resolvedCtaHref}
          class="action-primary w-full"
        >
          <span>{ctaLabel}</span>
          <i class="fas fa-paper-plane text-sm"></i>
        </a>
        <a
          href={whatsappHref}
          class="action-secondary action-secondary-dark w-full"
        >
          <span>WhatsApp</span>
          <i class="fab fa-whatsapp text-green-400 text-sm"></i>
        </a>
        <p class="text-sm text-slate-400">
          Respuesta inicial breve para definir si conviene diagnóstico, alcance o implementación.
        </p>
      </div>
    </div>
  </div>
</section>
