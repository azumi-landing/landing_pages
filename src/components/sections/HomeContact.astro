---
import { contactConfig, formTopics } from '../../data/contact';

const whatsappHref = `https://wa.me/${contactConfig.whatsappNumber}?text=${encodeURIComponent(contactConfig.whatsappMessage)}`;
---

<section id="contacto" class="py-24 px-6 bg-[#F8FAFC]">
  <div class="max-w-7xl mx-auto">
    <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] items-start">
      <div class="rounded-[2rem] bg-slate-950 text-white p-8 md:p-10 shadow-[0_40px_120px_rgba(15,23,42,0.18)]">
        <span class="inline-flex items-center rounded-full border border-blue-400/30 bg-blue-400/10 px-4 py-2 text-sm font-semibold text-blue-200">
          Conversación inicial
        </span>
        <h2 class="mt-6 text-4xl md:text-5xl font-bold leading-tight">
          Cuéntame de tu desafío
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-slate-300 max-w-2xl">
          Si estás evaluando una mejora operativa, una automatización o una solución digital más clara, cuéntame qué está pasando hoy. Te respondo con una mirada consultiva y una propuesta aterrizada, no con un pitch genérico.
        </p>

        <div class="mt-10 space-y-4">
          <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-200">Cómo trabajo este primer contacto</p>
            <p class="mt-3 text-slate-300">
              Revisamos el problema, entendemos el contexto y definimos si conviene una consultoría, una automatización o una implementación más amplia.
            </p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-blue-200">Respuesta</p>
            <p class="mt-3 text-slate-300">
              Respondo en {contactConfig.responseTime} con siguiente paso claro: correo, llamada breve o conversación por WhatsApp según el caso.
            </p>
          </div>
        </div>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row">
          <a
            href={whatsappHref}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center justify-center gap-3 rounded-2xl bg-green-500 px-6 py-4 text-base font-semibold text-slate-950 transition-all hover:-translate-y-0.5 hover:bg-green-400"
          >
            <i class="fab fa-whatsapp text-xl"></i>
            Escribir por WhatsApp
          </a>
          <a
            href={`mailto:${contactConfig.email}`}
            class="inline-flex items-center justify-center gap-3 rounded-2xl border border-white/15 bg-white/5 px-6 py-4 text-base font-semibold text-white transition-colors hover:bg-white/10"
          >
            <i class="fas fa-envelope text-blue-300"></i>
            {contactConfig.email}
          </a>
        </div>

        <div class="mt-6">
          <a
            href={contactConfig.calendlyUrl}
            class="inline-flex items-center gap-2 text-sm font-medium text-slate-300 transition-colors hover:text-white"
          >
            <i class="fas fa-calendar-alt text-blue-300"></i>
            Si ya tienes claridad, agenda una llamada
          </a>
        </div>
      </div>

      <div class="rounded-[2rem] border border-slate-200 bg-white p-8 md:p-10 shadow-[0_30px_80px_rgba(15,23,42,0.08)]">
        <div class="mb-8">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Formulario inicial</p>
          <h3 class="mt-3 text-2xl md:text-3xl font-bold text-slate-950">
            Dame un poco de contexto y te escribo de vuelta
          </h3>
        </div>

        <form class="space-y-5" id="home-contact-form">
          <div class="grid gap-5 md:grid-cols-2">
            <div>
              <label for="name" class="mb-2 block text-sm font-medium text-slate-700">Nombre *</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition-colors focus:border-blue-500 focus:bg-white"
                placeholder="Tu nombre"
              />
            </div>
            <div>
              <label for="email" class="mb-2 block text-sm font-medium text-slate-700">Email *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition-colors focus:border-blue-500 focus:bg-white"
                placeholder="tu@empresa.com"
              />
            </div>
          </div>

          <div class="grid gap-5 md:grid-cols-2">
            <div>
              <label for="company" class="mb-2 block text-sm font-medium text-slate-700">Empresa</label>
              <input
                type="text"
                id="company"
                name="company"
                class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition-colors focus:border-blue-500 focus:bg-white"
                placeholder="Nombre de tu empresa"
              />
            </div>
            <div>
              <label for="interest" class="mb-2 block text-sm font-medium text-slate-700">Qué necesitas *</label>
              <select
                id="interest"
                name="interest"
                required
                class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition-colors focus:border-blue-500 focus:bg-white"
              >
                {formTopics.map((topic) => (
                  <option value={topic.value} disabled={topic.disabled} selected={topic.selected}>
                    {topic.label}
                  </option>
                ))}
              </select>
            </div>
          </div>

          <div>
            <label for="challenge" class="mb-2 block text-sm font-medium text-slate-700">Desafío actual *</label>
            <textarea
              id="challenge"
              name="challenge"
              rows={6}
              required
              class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 outline-none transition-colors focus:border-blue-500 focus:bg-white"
              placeholder="Qué está pasando hoy, dónde se frena la operación y qué te gustaría mejorar."
            ></textarea>
          </div>

          <button
            type="submit"
            class="inline-flex w-full items-center justify-center rounded-2xl bg-slate-950 px-6 py-4 text-base font-semibold text-white transition-all hover:-translate-y-0.5 hover:bg-slate-900"
          >
            Enviar mensaje
          </button>

          <div id="home-contact-feedback" class="hidden rounded-2xl px-4 py-3 text-sm font-medium"></div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('home-contact-form');
  const feedback = document.getElementById('home-contact-feedback');
  const emailjsConfig = {
    serviceId: import.meta.env.PUBLIC_EMAILJS_SERVICE_ID || '',
    templateId: import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID || '',
    publicKey: import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY || ''
  };

  const setFeedback = (type, message) => {
    if (!(feedback instanceof HTMLElement)) return;

    feedback.className =
      type === 'success'
        ? 'block rounded-2xl border border-green-200 bg-green-50 px-4 py-3 text-sm font-medium text-green-700'
        : 'block rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700';
    feedback.textContent = message;
  };

  if (form instanceof HTMLFormElement) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const submitButton = form.querySelector('button[type="submit"]');
      const formData = new FormData(form);

      if (!emailjsConfig.serviceId || !emailjsConfig.templateId || !emailjsConfig.publicKey) {
        setFeedback('error', 'El formulario aún no está configurado. Usa WhatsApp o email mientras activamos el envío.');
        return;
      }

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.textContent = 'Enviando...';
      }

      try {
        const response = await fetch('https://api.emailjs.com/api/v1.0/email/send', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            service_id: emailjsConfig.serviceId,
            template_id: emailjsConfig.templateId,
            user_id: emailjsConfig.publicKey,
            template_params: {
              from_name: formData.get('name'),
              reply_to: formData.get('email'),
              company: formData.get('company'),
              interest: formData.get('interest'),
              challenge: formData.get('challenge'),
              source: 'home',
              to_email: 'hola@hguerra.com'
            }
          })
        });

        if (!response.ok) {
          throw new Error('EmailJS request failed');
        }

        form.reset();
        setFeedback('success', 'Mensaje enviado. Te contacto pronto para revisar el contexto.');
      } catch (error) {
        setFeedback('error', 'No pude enviar el formulario. Usa WhatsApp o email mientras revisamos el envío.');
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
          submitButton.textContent = 'Enviar mensaje';
        }
      }
    });
  }
</script>
