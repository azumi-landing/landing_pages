---
import { buildContactHref } from '../../../data/contact';
import Icon from '../../atoms/Icon.astro';

const diferencias = [
  {
    title: 'No somos un software genérico',
    subtitle: 'Somos un especialista que implementa',
    description: 'No vendemos licencias y te dejamos solo. Diseñamos tu operación específica y te acompañamos en la adopción con tu equipo de campo.',
    icon: 'fa-user-tie',
    highlight: 'Implementación en 2-3 semanas, no 6+ meses'
  },
  {
    title: 'Offline-first de verdad',
    subtitle: 'Diseñado para zonas sin cobertura',
    description: 'No es un modo offline añadido como feature. La app está construida desde cero para operar 100% sin internet, con sincronización inteligente.',
    icon: 'fa-wifi-slash',
    highlight: 'Funciona en minas, bosques, fincas remotas'
  },
  {
    title: 'Trazabilidad inmutable',
    subtitle: 'GPS + Timestamp + Fotos obligatorias',
    description: 'No es opcional. Cada registro incluye evidencia completa automáticamente. El operario no puede "olvidar" el GPS o la foto.',
    icon: 'fa-fingerprint',
    highlight: 'Auditorías sin hallazgos garantizadas'
  },
  {
    title: 'Órdenes automáticas desde alarmas',
    subtitle: 'Conexión directa a series de tiempo',
    description: 'Alarmas de tus sistemas SCADA/IoT generan órdenes de servicio automáticamente, asignadas al técnico más cercano.',
    icon: 'fa-robot',
    highlight: 'Tiempo de respuesta: de horas a minutos'
  },
  {
    title: 'Atención directa del especialista',
    subtitle: 'Trabajas conmigo, no con un call center',
    description: '+10 años de experiencia en operaciones de campo. Respuesta directa, compromiso total, sin intermediarios.',
    icon: 'fa-handshake',
    highlight: '+5M registros procesados en implementaciones reales'
  },
  {
    title: 'Integración enterprise lista',
    subtitle: 'SAP, Salesforce, Oracle, y más',
    description: 'APIs REST documentadas y conectores pre-construidos. No desarrollamos integraciones desde cero para cada cliente.',
    icon: 'fa-plug',
    highlight: 'Ecosistema unificado sin romper lo que funciona'
  }
];

const noSomos = [
  'Una plataforma genérica sin personalización para tu flujo específico',
  'Software que requiere conectividad 100% del tiempo',
  'Una herramienta de formularios simple sin trazabilidad inmutable',
  'Un equipo de ventas que desaparece post-implementación',
  'Un proceso de 6+ meses con consultoras y documentación infinita'
];

const fieldOpsContactHref = buildContactHref({
  service: 'gestion-operaciones-de-campo',
  originPath: '/gestion-de-operaciones-de-campo',
  originLabel: 'Gestión de Operaciones de Campo'
});
---

<section id="diferenciacion" class="py-24 px-6 bg-gradient-to-br from-slate-900 to-slate-800">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        ¿Por qué nosotros vs. alternativas?
      </h2>
      <p class="text-xl text-slate-300 max-w-3xl mx-auto">
        No somos la opción más barata. Somos la opción que garantiza resultados en semanas, 
        con trazabilidad que resiste auditorías y atención directa de quien diseñó la plataforma.
      </p>
    </div>

    <!-- Differences Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {diferencias.map((diff) => (
        <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-colors">
          <div class="w-12 h-12 rounded-xl bg-blue-500/20 flex items-center justify-center mb-4">
            <Icon name={diff.icon} size="lg" class="text-blue-400" />
          </div>
          <h3 class="text-xl font-bold text-white mb-1">{diff.title}</h3>
          <p class="text-sm text-blue-400 font-medium mb-3">{diff.subtitle}</p>
          <p class="text-slate-300 text-sm leading-relaxed mb-4">{diff.description}</p>
          <div class="border-t border-white/10 pt-3">
            <p class="text-xs text-green-400 font-medium">
              <Icon name="fa-check-circle" class="inline mr-1" />
              {diff.highlight}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- "Para quién NO somos" Section -->
    <div class="bg-gradient-to-br from-red-500/10 to-red-600/10 border border-red-500/30 rounded-2xl p-8">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-xl bg-red-500/30 flex items-center justify-center shrink-0">
          <Icon name="fa-times-circle" size="lg" class="text-red-400" />
        </div>
        <div class="flex-1">
          <h3 class="text-2xl font-bold text-white mb-4">Para quién NO somos la opción ideal</h3>
          <p class="text-slate-300 mb-4">Si buscas lo siguiente, probablemente no seamos la mejor elección:</p>
          <ul class="space-y-3">
            {noSomos.map((item) => (
              <li class="flex items-start gap-3 text-slate-300">
                <span class="text-red-400 font-bold shrink-0">×</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a 
        href={fieldOpsContactHref}
        class="inline-block px-8 py-4 bg-gradient-to-r from-blue-500 to-blue-600 text-white font-bold rounded-xl text-lg transition-all duration-300 hover:from-blue-600 hover:to-blue-700 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-blue-500/25 border border-blue-500/30"
      >
        Quiero saber si encajamos con mi operación →
      </a>
    </div>
  </div>
</section>
