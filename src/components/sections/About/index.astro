---
import { aboutCards, aboutFilter } from '../../../data/about';
import AboutCard from '../../molecules/AboutCard.astro';
import Icon from '../../atoms/Icon.astro';
---

<section id="about" class="py-24 px-6 bg-gradient-to-br from-slate-900 to-slate-800">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        Por qué trabajo conmigo
      </h2>
      <p class="text-xl text-slate-300 max-w-3xl mx-auto">
        Desarrollo soluciones de campo que realmente usan los operarios y que entregan visibilidad a la gerencia
      </p>
    </div>
    
    <!-- Cards Grid -->
    <div class="grid md:grid-cols-2 gap-6 mb-12">
      {aboutCards.map((card) => (
        <AboutCard card={card} />
      ))}
    </div>
    
    <!-- Filter Section -->
    <div class="card bg-gradient-to-br from-red-500/20 to-red-600/20 backdrop-blur-sm border border-red-500/30 rounded-2xl p-6 md:p-8">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-xl bg-red-500/30 flex items-center justify-center shrink-0">
          <Icon name={aboutFilter.icon} size="lg" class="text-red-400" />
        </div>
        <div>
          <h3 class="text-xl font-bold text-white mb-2">{aboutFilter.title}</h3>
          <p class="text-slate-300 mb-4">{aboutFilter.intro}</p>
          <ul class="space-y-2">
            {aboutFilter.exclusions.map((exclusion) => (
              <li class="text-sm text-slate-300 flex items-start gap-2">
                <span class="text-red-400 font-bold shrink-0">×</span>
                <span>{exclusion}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
