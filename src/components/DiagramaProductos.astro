---
import '../styles/diagramaProductos.css'
---

<section class="diagrama-section" id="flujo-productos">
  <div class="diagrama-container">
    <h2 class="diagrama-title">De la planilla de papel al dashboard en tiempo real</h2>
    <p class="diagrama-subtitle">Flujo completo: tu equipo de campo usa app móvil, tú controlas y decides desde la plataforma web</p>

    <div class="flujo-completo">

      <!-- NIVEL 1: ASIGNACIÓN DESDE WEB -->
      <div class="flujo-nivel highlight-blue">
        <div class="nivel-header">
          <i class="fas fa-tasks"></i>
          <span>1. ASIGNACIÓN DESDE LA WEB</span>
        </div>
        <div class="nivel-content">
          <div class="item-box">
            <i class="fas fa-calendar-alt"></i>
            <span>Programas tareas y rutas</span>
          </div>
          <div class="item-box">
            <i class="fas fa-user-plus"></i>
            <span>Asignas a operarios</span>
          </div>
          <div class="item-box">
            <i class="fas fa-bell"></i>
            <span>Notificación push al móvil</span>
          </div>
        </div>
      </div>

      <div class="flujo-arrow">
        <i class="fas fa-arrow-down"></i>
      </div>

      <!-- NIVEL 2: APP MÓVIL EN CAMPO -->
      <div class="flujo-nivel highlight-green">
        <div class="nivel-header">
          <i class="fas fa-mobile-alt"></i>
          <span>2. APP MÓVIL EN CAMPO</span>
        </div>
        <div class="nivel-content">
          <div class="item-box">
            <i class="fas fa-eye"></i>
            <span>Ve asignaciones pendientes</span>
          </div>
          <div class="item-box">
            <i class="fas fa-edit"></i>
            <span>Captura datos estructurados</span>
            <small>formularios con validación</small>
          </div>
          <div class="item-box">
            <i class="fas fa-camera"></i>
            <span>Fotos + GPS obligatorios</span>
          </div>
          <div class="item-box">
            <i class="fas fa-signature"></i>
            <span>Firma digital</span>
          </div>
        </div>
      </div>

      <div class="flujo-arrow">
        <i class="fas fa-arrow-down"></i>
      </div>

      <!-- NIVEL 3: SINCRONIZACIÓN -->
      <div class="flujo-nivel highlight-yellow">
        <div class="nivel-header">
          <i class="fas fa-sync"></i>
          <span>3. SINCRONIZACIÓN AUTOMÁTICA</span>
        </div>
        <div class="nivel-content single-col">
          <div class="feature-list">
            <div class="feature-item"><i class="fas fa-wifi"></i> Enviado en tiempo real (con internet)</div>
            <div class="feature-item"><i class="fas fa-download"></i> Almacenado localmente (modo offline)</div>
            <div class="feature-item"><i class="fas fa-upload"></i> Sincroniza automático al recuperar señal</div>
            <div class="feature-item"><i class="fas fa-check-circle"></i> Confirmación de recepción en web</div>
          </div>
        </div>
      </div>

      <div class="flujo-arrow">
        <i class="fas fa-arrow-down"></i>
      </div>

      <!-- NIVEL 4: PLATAFORMA WEB -->
      <div class="flujo-nivel highlight-purple">
        <div class="nivel-header">
          <i class="fas fa-laptop"></i>
          <span>4. PLATAFORMA WEB ADMINISTRATIVA</span>
        </div>
        <div class="nivel-content single-col">
          <div class="feature-list">
            <div class="feature-item"><i class="fas fa-chart-line"></i> Dashboard con métricas en tiempo real</div>
            <div class="feature-item"><i class="fas fa-map-marked-alt"></i> Mapa de ubicaciones y cobertura</div>
            <div class="feature-item"><i class="fas fa-clipboard-check"></i> Auditoría completa: quién, cuándo, dónde</div>
            <div class="feature-item"><i class="fas fa-bell"></i> Alertas por desviaciones o atrasos</div>
          </div>
        </div>
      </div>

      <div class="flujo-arrow">
        <i class="fas fa-arrow-down"></i>
      </div>

      <!-- NIVEL 5: INTEGRACIÓN -->
      <div class="flujo-nivel highlight-orange">
        <div class="nivel-header">
          <i class="fas fa-plug"></i>
          <span>5. INTEGRACIÓN CON TUS SISTEMAS</span>
        </div>
        <div class="nivel-content single-col">
          <div class="feature-list">
            <div class="feature-item"><i class="fas fa-sync"></i> Sincronización bidireccional</div>
            <div class="feature-item"><i class="fas fa-database"></i> ERP / SAP / CRM</div>
            <div class="feature-item"><i class="fas fa-file-export"></i> Exportación automática de reportes</div>
            <div class="feature-item"><i class="fas fa-key"></i> Single Sign-On (SSO)</div>
          </div>
        </div>
      </div>

      <div class="flujo-arrow">
        <i class="fas fa-arrow-down"></i>
      </div>

      <!-- NIVEL 6: RESULTADOS DE CAMPO -->
      <div class="flujo-nivel resultados">
        <div class="nivel-header">
          <i class="fas fa-trophy"></i>
          <span>RESULTADOS PARA TU OPERACIÓN DE CAMPO</span>
        </div>
        <div class="nivel-content single-col">
          <div class="resultados-grid">
            <div class="resultado-item">
              <i class="fas fa-eye"></i>
              <span><strong>100% visibilidad</strong> de operaciones en campo en tiempo real</span>
            </div>
            <div class="resultado-item">
              <i class="fas fa-check-double"></i>
              <span><strong>Hasta -60% errores</strong> de captura con validación en origen</span>
            </div>
            <div class="resultado-item">
              <i class="fas fa-clipboard-check"></i>
              <span>Auditoría completa con <strong>evidencia inmutable</strong> (fotos, GPS, timestamp)</span>
            </div>
            <div class="resultado-item">
              <i class="fas fa-chart-line"></i>
              <span>Decisiones basadas en datos <strong>actualizados al minuto</strong>, no al día siguiente</span>
            </div>
            <div class="resultado-item">
              <i class="fas fa-users"></i>
              <span><strong>90% menos llamadas</strong> de seguimiento al equipo de campo</span>
            </div>
          </div>
        </div>
      </div>

    </div>

    <div class="diagrama-footer">
      <p><i class="fas fa-rocket"></i> <strong>Implementación en semanas</strong> • App móvil + Plataforma web listas para usar</p>
    </div>
  </div>
</section>
