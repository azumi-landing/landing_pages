---
import SiteLayout from '../layouts/SiteLayout.astro';
import ServiceStatusCard from '../components/molecules/ServiceStatusCard.astro';
import ContactStrip from '../components/sections/ContactStrip.astro';
import { homeHeroBullets, homeProofPoints, homeWorkflowSteps } from '../data/home';
---

<SiteLayout
  title="HGuerra | Consultoría aplicada para operación, producto y automatización"
  description="Consultoría e implementación para convertir problemas operativos complejos en soluciones claras, adoptables y útiles para equipos reales."
  path="/"
>
  <main>
    <section id="inicio" class="relative overflow-hidden bg-[radial-gradient(circle_at_top_left,_rgba(59,130,246,0.18),_transparent_32%),linear-gradient(135deg,_#020617_0%,_#0f172a_52%,_#1e293b_100%)] px-6 pt-20 pb-24">
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-24 right-[-10%] h-72 w-72 rounded-full bg-cyan-400/10 blur-3xl"></div>
        <div class="absolute bottom-0 left-[-8%] h-80 w-80 rounded-full bg-blue-500/10 blur-3xl"></div>
      </div>

      <div class="relative max-w-7xl mx-auto grid gap-16 lg:grid-cols-[1.15fr_0.85fr] items-center">
        <div>
          <span class="inline-flex items-center rounded-full border border-blue-400/30 bg-blue-400/10 px-4 py-2 text-sm font-semibold text-blue-200 mb-6">
            Consultoría aplicada para ordenar operación, producto y automatización
          </span>
          <h1 class="max-w-4xl text-4xl md:text-6xl font-bold text-white leading-[1.05] mb-6">
            Te ayudo a convertir problemas operativos complejos en una solución clara que tu equipo pueda usar
          </h1>
          <p class="text-xl text-slate-300 leading-relaxed max-w-3xl mb-8">
            Trabajo contigo como consultor e implementador. Entiendo el contexto, bajo la complejidad a decisiones útiles y te acompaño a llevar la solución a operación sin venderte una receta genérica.
          </p>

          <div class="mb-10 space-y-3">
            {homeHeroBullets.map((bullet) => (
              <div class="flex items-start gap-3 text-slate-200">
                <span class="mt-1 inline-flex h-6 w-6 items-center justify-center rounded-full bg-blue-400/15 text-sm text-blue-200">✓</span>
                <p class="text-base md:text-lg leading-relaxed">{bullet}</p>
              </div>
            ))}
          </div>

          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="#contacto-general"
              class="px-8 py-4 bg-gradient-to-r from-blue-500 to-cyan-400 text-slate-950 font-bold rounded-2xl text-lg text-center transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-cyan-500/20"
            >
              Cuéntame tu desafío
            </a>
            <a
              href="#como-trabajo"
              class="px-8 py-4 bg-white/10 hover:bg-white/15 text-white font-bold rounded-2xl text-lg text-center transition-all duration-300 border border-white/15"
            >
              Ver cómo trabajo
            </a>
          </div>

          <div class="mt-12 flex flex-wrap gap-x-8 gap-y-4 border-t border-white/10 pt-8">
            {homeProofPoints.map((item) => (
              <div>
                <p class="text-2xl md:text-3xl font-bold text-white">{item.value}</p>
                <p class="mt-1 max-w-[14rem] text-sm leading-relaxed text-slate-400">{item.label}</p>
              </div>
            ))}
          </div>
        </div>

        <aside class="rounded-[2rem] border border-white/10 bg-white/5 p-8 backdrop-blur-md shadow-[0_35px_120px_rgba(15,23,42,0.35)]">
          <div class="mb-8 flex items-center gap-4">
            <div class="h-20 w-20 rounded-full overflow-hidden border-2 border-blue-400/30 shrink-0">
              <img
                src="/mi_foto_pro.jpeg"
                alt="Foto profesional de HGuerra"
                class="w-full h-full object-cover"
              />
            </div>
            <div>
              <p class="text-sm uppercase tracking-[0.2em] text-slate-400">HGuerra</p>
              <h2 class="mt-1 text-2xl font-bold text-white">Consultor + implementador</h2>
              <p class="mt-2 text-sm font-medium text-cyan-200">Producto, automatización y operación aterrizados a tu realidad</p>
            </div>
          </div>

          <p class="text-lg leading-relaxed text-slate-200">
            No trabajo como intermediario comercial. Me involucro en el diagnóstico, en la definición de la solución y en la implementación para que lo que se decide tenga sentido técnico y operativo.
          </p>

          <div class="my-8 h-px bg-white/10"></div>

          <div class="space-y-5 text-sm text-slate-300">
            <div>
              <p class="text-xs uppercase tracking-[0.18em] text-cyan-200">Cuando suelo aportar más valor</p>
              <p class="mt-2 leading-relaxed">
                Cuando hay fricción entre operación, datos y adopción, y necesitas a alguien que ordene el problema antes de construir.
              </p>
            </div>
            <div>
              <p class="text-xs uppercase tracking-[0.18em] text-cyan-200">Tipo de relación</p>
              <p class="mt-2 leading-relaxed">
                Trabajo directo, con criterio de negocio y ejecución, para que la conversación no se quede en ideas bonitas o herramientas sueltas.
              </p>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section id="como-trabajo" class="py-24 px-6 bg-[#F8FAFC]">
      <div class="max-w-7xl mx-auto">
        <div class="max-w-3xl mb-14">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500 mb-4">
            Cómo trabajo
          </p>
          <h2 class="text-4xl md:text-5xl font-bold text-[#1E293B] mb-5">
            Cómo trabajo
          </h2>
          <p class="text-xl text-[#475569] leading-relaxed">
            La relación consultor-cliente no empieza con una demo, empieza entendiendo el problema correcto. Mi trabajo es ayudarte a leer la operación, definir una salida viable y acompañar la ejecución hasta que el cambio se use de verdad.
          </p>
        </div>

        <div class="grid gap-6 lg:grid-cols-3">
          {homeWorkflowSteps.map((step) => (
            <article class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-[0_20px_60px_rgba(15,23,42,0.08)]">
              <div class="flex items-center justify-between gap-4 mb-6">
                <span class="inline-flex rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white">
                  Paso {step.step}
                </span>
                <span class="text-sm font-medium text-slate-400">Proceso consultivo</span>
              </div>
              <h3 class="text-2xl font-bold text-slate-950 leading-tight">{step.title}</h3>
              <p class="mt-4 text-base leading-relaxed text-slate-600">{step.description}</p>
              <div class="mt-8 space-y-3 border-t border-slate-200 pt-6">
                {step.points.map((point) => (
                  <div class="flex items-start gap-3">
                    <span class="mt-1 inline-flex h-5 w-5 items-center justify-center rounded-full bg-blue-50 text-xs font-bold text-blue-600">•</span>
                    <p class="text-sm leading-relaxed text-slate-700">{point}</p>
                  </div>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="servicios" class="py-24 px-6 bg-gradient-to-br from-slate-900 to-slate-800">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
            Líneas de servicio
          </h2>
          <p class="text-xl text-slate-300 max-w-3xl mx-auto">
            Tres frentes para resolver problemas operativos con distintos niveles de madurez y velocidad.
          </p>
        </div>

        <div class="grid lg:grid-cols-3 gap-8">
          <ServiceStatusCard
            title="Gestión de Operaciones de Campo"
            description="La línea más madura del sitio. Plataforma y experiencia comercial ya desarrolladas para operaciones con app móvil offline, dashboard web y trazabilidad completa."
            href="/gestion-de-operaciones-de-campo"
            cta="Ver solución"
            icon="fa-map-marked-alt"
            status="available"
            highlight={true}
          />
          <ServiceStatusCard
            title="Automatización con IA Agéntica"
            description="Servicio orientado a agentes, orquestación y automatización inteligente sobre procesos y datos de negocio. En esta fase se publica como vista previa."
            href="/automatizacion-con-ia-agentica"
            cta="Ver vista previa"
            icon="fa-robot"
            status="coming-soon"
          />
          <ServiceStatusCard
            title="Automatización de Procesos"
            description="Línea enfocada en rediseñar flujos, eliminar trabajo manual e integrar sistemas para reducir fricción operativa. En esta fase se publica como vista previa."
            href="/automatizacion-de-procesos"
            cta="Ver vista previa"
            icon="fa-gears"
            status="coming-soon"
          />
        </div>
      </div>
    </section>

    <ContactStrip
      ctaHref="/contacto"
      title="¿Quieres ordenar una operación, rediseñar un flujo o definir una solución digital viable?"
      description="Abrimos una conversación inicial con un formulario único. Si el caso encaja, definimos rápido si conviene consultoría, automatización o implementación."
    />
  </main>
</SiteLayout>
