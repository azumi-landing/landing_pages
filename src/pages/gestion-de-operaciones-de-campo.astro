---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero/index.astro';
import ElProblema from '../components/sections/ElProblema/index.astro';
import Sectores from '../components/sections/Sectores/index.astro';
import Servicios from '../components/sections/Servicios/index.astro';
import DiagramaProductos from '../components/sections/DiagramaProductos/index.astro';
import Resultados from '../components/sections/Resultados/index.astro';
import CasosDeExito from '../components/sections/CasosDeExito/index.astro';
import Seguridad from '../components/sections/Seguridad/index.astro';
import Diferenciacion from '../components/sections/Diferenciacion/index.astro';
import About from '../components/sections/About/index.astro';
import Investiger from '../components/sections/Investiger/index.astro';
import FAQ from '../components/sections/FAQ/index.astro';
import Contact from '../components/sections/Contact/index.astro';
import RelatedServices from '../components/sections/RelatedServices.astro';
import { fieldOperationsTheme } from '../data/serviceThemes';
import { fieldOperationsFaqs } from '../data/faqs';
import {
  buildBreadcrumbSchema,
  buildFAQSchema,
  buildServiceSchema
} from '../data/site';
---

<BaseLayout
  title="HGuerra | Gestión de Operaciones de Campo"
  description="Software personalizado para operaciones de campo. App móvil offline, dashboard web en vivo y auditoría completa con GPS y fotos."
  path="/gestion-de-operaciones-de-campo"
  image="/og-field-operations.svg"
  schemas={[
    buildServiceSchema({
      name: 'Gestión de Operaciones de Campo',
      description: 'Software personalizado para operaciones de campo con app móvil offline, dashboard web y trazabilidad operativa.',
      path: '/gestion-de-operaciones-de-campo'
    }),
    buildBreadcrumbSchema([
      { name: 'Inicio', path: '/' },
      { name: 'Gestión de Operaciones de Campo', path: '/gestion-de-operaciones-de-campo' }
    ]),
    buildFAQSchema(fieldOperationsFaqs)
  ]}
>
  <main>
    <Hero />
    <ElProblema />
    <Sectores />
    <Servicios />
    <DiagramaProductos />
    <Resultados />
    <CasosDeExito />
    <Seguridad />
    <Diferenciacion />
    <About />
    <Investiger />
    <RelatedServices currentPath="/gestion-de-operaciones-de-campo" />
    <FAQ />
    <Contact theme={fieldOperationsTheme} />
  </main>
</BaseLayout>

<script>
  import { initModal } from '../utils/modals';

  if (typeof window !== 'undefined') {
    document.addEventListener('DOMContentLoaded', () => {
      initModal();
    });
  }
</script>
