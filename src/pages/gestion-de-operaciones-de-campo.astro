---
import PageLayout from '../layouts/PageLayout.astro';
import ServiceLanding from '../components/templates/ServiceLanding.astro';
import { fieldOperationsLanding } from '../data/serviceLandings';
import {
  buildBreadcrumbSchema,
  buildFAQSchema,
  buildServiceSchema
} from '../data/site';

const sectionNavItems = [
  { id: 'inicio', label: 'Inicio' },
  { id: 'problema', label: 'Problema' },
  { id: 'capacidades', label: 'Qué incluye' },
  { id: 'como-funciona', label: 'Cómo funciona' },
  { id: 'casos-aplicaciones', label: 'Casos' },
  { id: 'prueba', label: 'Prueba' },
  { id: 'stack', label: 'Stack' },
  { id: 'diferenciacion', label: 'Diferenciación' },
  { id: 'faq', label: 'FAQ' },
  { id: 'contacto', label: 'Contacto' }
];
---

<PageLayout
  title={fieldOperationsLanding.seoTitle}
  description={fieldOperationsLanding.seoDescription}
  path={fieldOperationsLanding.path}
  image={fieldOperationsLanding.seoImage}
  bodyVariant="mixed"
  showSectionNav={true}
  sectionNavItems={sectionNavItems}
  schemas={[
    buildServiceSchema({
      name: 'Gestión de Operaciones de Campo',
      description: fieldOperationsLanding.seoDescription,
      path: fieldOperationsLanding.path
    }),
    buildBreadcrumbSchema([
      { name: 'Inicio', path: '/' },
      { name: 'Gestión de Operaciones de Campo', path: fieldOperationsLanding.path }
    ]),
    buildFAQSchema(fieldOperationsLanding.faqs)
  ]}
>
  <ServiceLanding config={fieldOperationsLanding} />
</PageLayout>
