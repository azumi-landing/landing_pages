---
export const prerender = false;

import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/sections/ContactForm.astro';
import {
  getWhatsAppHref,
  getContactContextByPath,
  getContactServiceLabel,
  isValidContactService,
  contactConfig
} from '../data/contact';
import { buildBreadcrumbSchema, buildContactPageSchema } from '../data/site';

const serviceParam = Astro.url.searchParams.get('service');
const originPath = Astro.url.searchParams.get('origin') ?? '';
const originLabelParam = Astro.url.searchParams.get('originLabel');
const hasPresetContext = Boolean(serviceParam || originPath || originLabelParam);
const derivedContext = originPath ? getContactContextByPath(originPath) : null;
const defaultService = isValidContactService(serviceParam)
  ? serviceParam
  : derivedContext?.service ?? '';
const originLabel = hasPresetContext
  ? originLabelParam ?? (originPath ? derivedContext?.originLabel ?? originPath : getContactServiceLabel(defaultService))
  : '';
const serviceLabel = defaultService ? getContactServiceLabel(defaultService) : 'Por definir';
const whatsappHref = getWhatsAppHref();
---

<PageLayout
  title="Diagnóstico gratuito de 30 min para tu operación — HGuerra"
  description="Cuéntame el cuello de botella de tu operación. Respuesta en menos de 1 hora. Diagnóstico de 30 min sin costo. Sin presión, sin chatbot."
  path="/contacto"
  image="/og-contact.png"
  bodyVariant="mixed"
  schemas={[
    buildContactPageSchema({
      path: '/contacto',
      title: 'Diagnóstico gratuito de 30 min para tu operación — HGuerra',
      description: 'Cuéntame el cuello de botella de tu operación. Respuesta en menos de 1 hora. Diagnóstico de 30 min sin costo. Sin presión, sin chatbot.'
    }),
    buildBreadcrumbSchema([
      { name: 'Inicio', path: '/' },
      { name: 'Contacto', path: '/contacto' }
    ])
  ]}
>
  <main>
    <section class="section-shell-hero section-deep relative overflow-hidden">
      <div class="absolute inset-0 opacity-15">
        <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.14) 1px, transparent 0); background-size: 42px 42px;"></div>
      </div>

      <div class="page-container relative">
        <div class="section-intro max-w-4xl">
          <span class="eyebrow-pill eyebrow-pill-dark mb-6">
            Contacto
          </span>
          <h1 class="text-4xl md:text-6xl font-bold text-white leading-tight mb-6">
            Tu operación sigue en Excel, WhatsApp y papel — cuéntame el cuello de botella y te digo cómo sacarlo en semanas
          </h1>
          <p class="text-xl text-slate-300 leading-relaxed max-w-3xl">
            Si vienes de una página específica, ya tengo tu contexto — así respondemos sin empezar de cero. Si no, cuéntame el problema en 3 preguntas y te respondo en menos de 1 hora.
          </p>
        </div>
      </div>
    </section>

    <section class="section-shell section-light">
      <div class="page-container grid gap-8 lg:grid-cols-[1.05fr_0.95fr] items-start">
        <section class="surface-card surface-panel p-8">
          <div class="mb-8 flex flex-wrap items-center gap-3">
            <span class="eyebrow-pill">
              Tema detectado
            </span>
            <span class="rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700">
              {serviceLabel}
            </span>
          </div>

          {originLabel ? (
            <p class="text-slate-600 leading-relaxed mb-6">
              Ya sé que vienes desde <span class="font-semibold text-slate-950">{originLabel}</span>. Así respondo directo sobre ese servicio sin perder tiempo en contexto.
            </p>
          ) : (
            <p class="text-slate-600 leading-relaxed mb-6">
              Completa el formulario. En menos de 1 hora te cuento si lo tuyo es diagnóstico gratuito, implementación directa, o si honestamente no es un fit.
            </p>
          )}

          <ContactForm
            defaultService={defaultService}
            originPath={originPath}
            originLabel={originLabel}
            tone="light"
          />
        </section>

        <aside class="space-y-6">
          <div class="surface-soft p-8">
            <p class="section-eyebrow text-slate-500">Qué puedes esperar</p>
            <h2 class="text-2xl font-bold text-slate-950 mb-4">Una respuesta que reconozca tu problema, no una respuesta de catálogo</h2>
            <ul class="space-y-4 text-slate-600">
              <li class="flex items-start gap-3">
                <span class="mt-0.5 inline-flex h-6 w-6 items-center justify-center rounded-full bg-slate-950 text-xs font-bold text-white">1</span>
                <span>Respuesta en <strong class="text-slate-950">menos de 1 hora</strong> (horario laboral) — yo mismo, sin chatbot ni asistente.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 inline-flex h-6 w-6 items-center justify-center rounded-full bg-slate-950 text-xs font-bold text-white">2</span>
                <span>En 15 minutos, te digo si lo tuyo es diagnóstico (30 min gratis), implementación directa, o si no es un fit.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 inline-flex h-6 w-6 items-center justify-center rounded-full bg-slate-950 text-xs font-bold text-white">3</span>
                <span>Una conversación centrada en el flujo real de tu operación, no en una presentación genérica.</span>
              </li>
            </ul>
          </div>

          <div class="rounded-2xl border border-yellow-200 bg-yellow-50 p-6">
            <p class="text-sm font-semibold text-slate-800 mb-2">Sin presión. Sin compromiso.</p>
            <p class="text-sm text-slate-600 leading-relaxed">
              Si después de 30 minutos no es un fit, te lo digo directo en la misma llamada. No voy a intentar venderte algo que no necesitas.
            </p>
          </div>

          <div class="cta-band p-8">
            <p class="section-eyebrow text-cyan-300">Canales alternos</p>
            <div class="space-y-4">
              <a
                href={whatsappHref}
                class="action-primary w-full"
              >
                <span>Abrir WhatsApp</span>
                <i class="fab fa-whatsapp text-sm"></i>
              </a>
              <a
                href="/sobre-mi"
                class="action-secondary action-secondary-dark w-full"
              >
                <span>Ver mi historial de casos y enfoque</span>
                <i class="fas fa-user-tie text-sm"></i>
              </a>
            </div>
          </div>
        </aside>
      </div>
    </section>
  </main>
</PageLayout>
