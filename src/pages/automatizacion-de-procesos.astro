---
import PageLayout from '../layouts/PageLayout.astro';
import ServiceLanding from '../components/templates/ServiceLanding.astro';
import { processAutomationLanding } from '../data/serviceLandings';
import {
  buildBreadcrumbSchema,
  buildFAQSchema,
  buildServiceSchema
} from '../data/site';

const sectionNavItems = [
  { id: 'inicio', label: 'Inicio' },
  { id: 'problema', label: 'Problema' },
  { id: 'capacidades', label: 'Capacidades' },
  { id: 'como-funciona', label: 'Cómo funciona' },
  { id: 'casos-aplicaciones', label: 'Casos' },
  { id: 'prueba', label: 'Prueba' },
  { id: 'stack', label: 'Stack' },
  { id: 'diferenciacion', label: 'Diferenciación' },
  { id: 'faq', label: 'FAQ' },
  { id: 'contacto', label: 'Contacto' }
];
---

<PageLayout
  title={processAutomationLanding.seoTitle}
  description={processAutomationLanding.seoDescription}
  path={processAutomationLanding.path}
  image={processAutomationLanding.seoImage}
  bodyVariant="mixed"
  showSectionNav={true}
  sectionNavItems={sectionNavItems}
  schemas={[
    buildServiceSchema({
      name: processAutomationLanding.title,
      description: processAutomationLanding.seoDescription,
      path: processAutomationLanding.path
    }),
    buildBreadcrumbSchema([
      { name: 'Inicio', path: '/' },
      { name: 'Automatización de Procesos', path: processAutomationLanding.path }
    ]),
    buildFAQSchema(processAutomationLanding.faqs)
  ]}
>
  <ServiceLanding config={processAutomationLanding} />
</PageLayout>
