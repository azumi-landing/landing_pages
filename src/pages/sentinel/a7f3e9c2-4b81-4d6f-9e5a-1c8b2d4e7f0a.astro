---
import '../../styles/global.css';

const uuid = 'a7f3e9c2-4b81-4d6f-9e5a-1c8b2d4e7f0a';
const pageUrl = `https://hguerra.com/sentinel/${uuid}`;
const ogImage = 'https://hguerra.com/mi_foto_pro.jpeg';
const title = 'SENTINEL — De la detección al afloramiento';
const description = 'SENTINEL: detección inteligente de pérdidas no técnicas para ENEE. Un ciclo inteligente, trazable y auditable.';
---
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="googlebot" content="noindex, nofollow" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_HN" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={pageUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="icon" type="image/svg+xml" href="/hg-favicon.svg">

    <style>
      :root {
        --sentinel-blue: #0066CC;
        --sentinel-yellow: #FFB800;
        --sentinel-dark: #1A1A2E;
      }
      html { scroll-behavior: smooth; }
      body {
        font-family: 'Montserrat', system-ui, sans-serif;
        background: #1A1A2E;
        color: white;
        -webkit-font-smoothing: antialiased;
      }
      .mono { font-family: 'JetBrains Mono', ui-monospace, monospace; }

      [data-reveal] {
        opacity: 0;
        transform: translateY(2rem);
        transition: opacity .8s ease-out, transform .8s ease-out;
        will-change: opacity, transform;
      }
      [data-reveal].is-visible {
        opacity: 1;
        transform: none;
      }
      [data-reveal][data-delay="1"] { transition-delay: .15s; }
      [data-reveal][data-delay="2"] { transition-delay: .30s; }
      [data-reveal][data-delay="3"] { transition-delay: .45s; }

      .cursor::after {
        content: '▋';
        margin-left: 2px;
        color: #FFB800;
        animation: blink 1s step-end infinite;
      }
      @keyframes blink { 50% { opacity: 0; } }

      .chevron-bounce {
        animation: bounce 2s ease-in-out infinite;
      }
      @keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(8px); }
      }

      .cycle-spin {
        animation: spin 24s linear infinite;
      }
      @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }

      .chaos-arrow {
        stroke: #FFB800;
        stroke-width: 2;
        fill: none;
        stroke-linecap: round;
        opacity: 0.7;
      }
      .chaos-cell {
        font-family: 'JetBrains Mono', monospace;
        font-size: 9px;
      }

      .phone-notch {
        width: 110px;
        height: 22px;
        border-radius: 0 0 14px 14px;
        background: #0b0b14;
        margin: 0 auto;
      }

      .bar {
        transition: height 1.2s cubic-bezier(.2,.8,.2,1);
      }
      .is-visible .bar {
        height: var(--bar-final);
      }
      .bar {
        height: 0;
      }

      .grid-chaos {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 2px;
      }

      /* Side nav */
      [data-nav]:disabled {
        opacity: 0.25;
        pointer-events: none;
      }
      .nav-dot {
        width: 8px;
        height: 8px;
        border-radius: 9999px;
        background: rgba(255,255,255,0.25);
        transition: all .25s ease;
      }
      .nav-dot.active {
        background: #FFB800;
        transform: scale(1.6);
      }

      /* Modal base */
      [data-modal-id] {
        display: none;
        position: fixed;
        inset: 0;
        align-items: center;
        justify-content: center;
        z-index: 100;
        padding: 1rem;
      }
      [data-modal-id].is-open {
        display: flex;
      }

      /* Mini sparkline inside phone mockup */
      .sparkline {
        display: flex;
        align-items: flex-end;
        gap: 3px;
        height: 22px;
      }
      .sparkline > span {
        flex: 1;
        background: #0066CC;
        border-radius: 1px;
        opacity: 0.8;
      }

      /* === Lean design tokens === */
      :root {
        --ink: #1A1A2E;
        --muted: #64748b;
        --accent: #0066CC;
        --accent-2: #FFB800;
        --ok: #34d399;
        --line-light: rgba(26,26,46,0.10);
        --line-dark: rgba(255,255,255,0.12);
        --shadow-lift: 0 24px 60px rgba(15,23,42,0.10);
      }

      /* Typographic roles */
      .t-meta {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        font-weight: 600;
      }
      .t-head {
        font-family: 'Montserrat', system-ui, sans-serif;
        font-size: clamp(2rem, 3.6vw, 3.25rem);
        font-weight: 800;
        line-height: 1.05;
        letter-spacing: -0.02em;
      }
      .t-lede {
        font-size: clamp(1.0625rem, 1.35vw, 1.25rem);
        line-height: 1.65;
      }

      /* Narrative thread (vertical rule on the text column) */
      .thread {
        border-left: 1px solid rgba(0,102,204,0.25);
        padding-left: 1.75rem;
      }
      @media (min-width: 1024px) {
        .thread { padding-left: 2.25rem; }
      }

      /* Yellow highlight mark under the brand letter */
      .mark-yellow {
        background-image: linear-gradient(transparent 68%, rgba(255,184,0,0.55) 68%);
      }

      /* Ghost link — secondary actions ("detalles técnicos") */
      .ghost-link {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 11px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0 0 2px 0;
        border: 0;
        border-bottom: 1px solid currentColor;
        background: none;
        cursor: pointer;
        opacity: 0.7;
        transition: gap .25s ease, opacity .2s ease;
      }
      .ghost-link:hover { gap: 0.95rem; opacity: 1; }
      .ghost-link i { font-size: 10px; }
    </style>
  </head>
  <body>
    <!-- STICKY SIDE NAV -->
    <nav aria-label="Navegación de actos" class="fixed right-3 md:right-6 top-1/2 -translate-y-1/2 z-50 flex flex-col items-center gap-2 rounded-full border border-white/10 bg-[#1A1A2E]/80 backdrop-blur-md px-2 py-2.5">
      <button data-nav="prev" aria-label="Sección anterior" class="h-9 w-9 flex items-center justify-center rounded-full text-white/85 hover:bg-white/10 transition">
        <i class="fa-solid fa-chevron-up text-xs"></i>
      </button>

      <span data-nav-counter class="t-meta text-white/70 py-1">01 / 11</span>

      <button data-nav="next" aria-label="Sección siguiente" class="h-9 w-9 flex items-center justify-center rounded-full text-white/85 hover:bg-white/10 transition">
        <i class="fa-solid fa-chevron-down text-xs"></i>
      </button>
    </nav>

    <main>
      <!-- 0. HERO / INTRO -->
      <section id="sec-0" data-reveal class="relative min-h-screen flex items-center justify-center px-6 py-24 overflow-hidden bg-[#1A1A2E]">
        <div class="absolute inset-0 overflow-hidden pointer-events-none">
          <div class="absolute -top-40 -left-40 h-[520px] w-[520px] rounded-full bg-[#0066CC]/20 blur-3xl"></div>
          <div class="absolute -bottom-40 -right-40 h-[520px] w-[520px] rounded-full bg-[#FFB800]/10 blur-3xl"></div>
          <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 24px 24px;"></div>
        </div>

        <div class="relative max-w-5xl mx-auto w-full text-center">
          <p class="t-meta text-slate-400 mb-10">/ ENEE · Honduras</p>

          <h1 class="text-6xl md:text-8xl lg:text-9xl font-extrabold tracking-tight mb-8 leading-none">
            SENT<span class="mark-yellow">I</span>NEL
          </h1>

          <p class="t-lede text-slate-300 max-w-3xl mx-auto mb-4 font-light">
            Detección inteligente de pérdidas no técnicas.
          </p>
          <p class="t-meta text-[#FFB800] mb-16">De la detección al afloramiento</p>

          <div class="flex flex-col items-center gap-3 text-slate-500">
            <span class="t-meta">Desliza para recorrer el ciclo</span>
            <i class="fa-solid fa-chevron-down text-2xl chevron-bounce text-[#0066CC]"></i>
          </div>
        </div>
      </section>

      <!-- ACTO 1 — EL PROBLEMA -->
      <section id="sec-1" data-reveal class="min-h-screen flex items-center px-6 py-24 bg-white text-[#1A1A2E]">
        <div class="max-w-6xl mx-auto w-full grid lg:grid-cols-2 gap-16 items-center">
          <div class="thread">
            <p class="t-meta mb-6 text-[#0066CC]">/ 01 &nbsp; El problema</p>
            <h2 class="t-head mb-6">
              Dos decisiones a ciegas, encadenadas.
            </h2>
            <p class="t-lede text-slate-600">
              Sobre <strong class="text-[#1A1A2E]">+2M clientes</strong>, el analista decide a quién investigar y a qué cuadrilla enviar — sin modelo de scoring, sin ruteo, sin feedback del campo. <strong class="text-[#1A1A2E]">El problema no es el tipeo. Es el criterio.</strong>
            </p>
            <div class="mt-10 space-y-2">
              <div class="inline-flex items-center gap-4 border-l-2 border-[#FFB800] pl-4 py-1">
                <span class="t-meta text-[#FFB800]">paso 1</span>
                <span class="text-sm text-slate-600">¿a quién investigar? · selección al ojo</span>
              </div>
              <div class="inline-flex items-center gap-4 border-l-2 border-[#FFB800] pl-4 py-1">
                <span class="t-meta text-[#FFB800]">paso 2</span>
                <span class="text-sm text-slate-600">¿qué cuadrilla la atiende? · asignación sin ruteo</span>
              </div>
            </div>
            <div class="mt-10">
              <button data-modal-target="act1" class="ghost-link text-[#0066CC]">
                detalles técnicos <i class="fa-solid fa-arrow-right-long"></i>
              </button>
            </div>
          </div>

          <div data-reveal data-delay="1" class="relative">
            <!-- Excel chaotic mockup -->
            <div class="relative rounded-xl border border-slate-300 bg-slate-50 shadow-2xl overflow-hidden">
              <div class="flex items-center gap-2 px-4 py-2 bg-slate-200 border-b border-slate-300">
                <div class="flex gap-1.5">
                  <span class="w-3 h-3 rounded-full bg-red-400"></span>
                  <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
                  <span class="w-3 h-3 rounded-full bg-green-400"></span>
                </div>
                <span class="mono text-xs text-slate-600 ml-2">ods_abril_final_v7_REVISADO.xlsx</span>
              </div>
              <div class="relative p-4">
                <div class="grid-chaos">
                  <div class="chaos-cell h-7 bg-slate-200 text-slate-500 flex items-center justify-center font-bold">A</div>
                  <div class="chaos-cell h-7 bg-slate-200 text-slate-500 flex items-center justify-center font-bold">B</div>
                  <div class="chaos-cell h-7 bg-slate-200 text-slate-500 flex items-center justify-center font-bold">C</div>
                  <div class="chaos-cell h-7 bg-slate-200 text-slate-500 flex items-center justify-center font-bold">D</div>
                  <div class="chaos-cell h-7 bg-slate-200 text-slate-500 flex items-center justify-center font-bold">E</div>
                  <div class="chaos-cell h-7 bg-slate-200 text-slate-500 flex items-center justify-center font-bold">F</div>

                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">4821</div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">N-5</div>
                  <div class="chaos-cell h-7 bg-yellow-100 border border-yellow-300 flex items-center justify-center">?</div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">12.3</div>
                  <div class="chaos-cell h-7 bg-red-100 border border-red-300 flex items-center justify-center text-red-700">!</div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">-</div>

                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">4822</div>
                  <div class="chaos-cell h-7 bg-yellow-100 border border-yellow-300 flex items-center justify-center">?</div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">S-2</div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center"></div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">8.1</div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">??</div>

                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">4823</div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">C-1</div>
                  <div class="chaos-cell h-7 bg-red-100 border border-red-300 flex items-center justify-center text-red-700">ERR</div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">4.2</div>
                  <div class="chaos-cell h-7 bg-yellow-100 border border-yellow-300 flex items-center justify-center">?</div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">-</div>

                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">4824</div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">N-3</div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">22.0</div>
                  <div class="chaos-cell h-7 bg-yellow-100 border border-yellow-300 flex items-center justify-center">?</div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center"></div>
                  <div class="chaos-cell h-7 bg-red-100 border border-red-300 flex items-center justify-center text-red-700">!</div>

                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">4825</div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">?</div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">?</div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">?</div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">?</div>
                  <div class="chaos-cell h-7 bg-white border border-slate-200 flex items-center justify-center">?</div>
                </div>

                <!-- Chaotic arrows overlay -->
                <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 400 240" preserveAspectRatio="none">
                  <path class="chaos-arrow" d="M 40 60 Q 120 20 200 80 T 380 50" />
                  <path class="chaos-arrow" d="M 360 180 Q 280 140 200 200 T 30 190" />
                  <path class="chaos-arrow" d="M 50 200 L 200 80 L 340 180" />
                  <circle cx="200" cy="120" r="18" fill="#FFB800" fill-opacity="0.3" stroke="#FFB800" stroke-width="2" />
                  <text x="200" y="127" text-anchor="middle" font-size="20" font-weight="bold" fill="#1A1A2E">?</text>
                </svg>
              </div>
              <div class="px-4 py-2 bg-slate-100 border-t border-slate-300 mono text-[10px] text-slate-500">
                Listo · 47 medidores · sin criterio
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ACTO 2 — LA DETECCIÓN -->
      <section id="sec-2" data-reveal class="min-h-screen flex items-center px-6 py-24 bg-[#1A1A2E] text-white">
        <div class="max-w-6xl mx-auto w-full grid lg:grid-cols-2 gap-16 items-center">
          <div class="thread">
            <p class="t-meta mb-6 text-[#FFB800]">/ 02 &nbsp; La detección</p>
            <h2 class="t-head mb-6">
              El criterio sale de los datos, no del ojo.
            </h2>
            <p class="t-lede text-slate-300">
              No son las series de consumo. Es el <strong class="text-white">contexto</strong>: <span class="mono text-[#FFB800]">geohash</span>, región, circuito, temporada e histórico de la cuenta. El agente cruza todo eso —para cada medidor, convencional o telegestionado— y saca señales que el ojo no ve.
            </p>
            <div class="mt-8">
              <p class="t-meta text-slate-400 mb-3">inputs</p>
              <div class="flex flex-wrap gap-2">
                <span class="inline-flex items-center gap-2 rounded-full border border-white/15 px-3.5 py-1.5 text-xs text-slate-200"><i class="fa-solid fa-bolt text-[#0066CC]"></i> consumos mensuales</span>
                <span class="inline-flex items-center gap-2 rounded-full border border-white/15 px-3.5 py-1.5 text-xs text-slate-200"><i class="fa-solid fa-clock-rotate-left text-[#0066CC]"></i> ODS históricas</span>
                <span class="inline-flex items-center gap-2 rounded-full border border-white/15 px-3.5 py-1.5 text-xs text-slate-200"><i class="fa-solid fa-bell text-[#0066CC]"></i> alarmas (telegestión)</span>
                <span class="inline-flex items-center gap-2 rounded-full border border-[#FFB800]/40 px-3.5 py-1.5 text-xs text-[#FFB800]"><i class="fa-solid fa-location-dot"></i> geohash · región · circuito · temporada</span>
              </div>
            </div>
            <div class="mt-6">
              <p class="t-meta text-slate-400 mb-3">stack</p>
              <div class="flex flex-wrap gap-2">
                <span class="inline-flex items-center gap-2 rounded-full border border-white/15 px-3.5 py-1.5 text-xs text-slate-200"><i class="fa-solid fa-brain text-[#0066CC]"></i> ML · Anomaly detection</span>
                <span class="inline-flex items-center gap-2 rounded-full border border-white/15 px-3.5 py-1.5 text-xs text-slate-200"><i class="fa-solid fa-diagram-project text-[#0066CC]"></i> Deep Learning</span>
                <span class="inline-flex items-center gap-2 rounded-full border border-white/15 px-3.5 py-1.5 text-xs text-slate-200"><i class="fa-solid fa-database text-[#0066CC]"></i> RAG sobre histórico</span>
                <span class="inline-flex items-center gap-2 rounded-full border border-[#FFB800]/40 px-3.5 py-1.5 text-xs text-[#FFB800]"><i class="fa-solid fa-plug"></i> MCP · <span class="mono">sentinel.query_meters</span></span>
              </div>
            </div>
            <div class="mt-10">
              <button data-modal-target="act2" class="ghost-link text-[#FFB800]">
                detalles técnicos <i class="fa-solid fa-arrow-right-long"></i>
              </button>
            </div>
          </div>

          <div data-reveal data-delay="1" class="relative">
            <!-- CLI terminal mockup -->
            <div class="rounded-xl bg-black/80 ring-1 ring-[#0066CC]/60 shadow-[0_30px_80px_rgba(0,102,204,0.25)] overflow-hidden backdrop-blur">
              <div class="flex items-center gap-2 px-4 py-3 bg-slate-900/90 border-b border-slate-800">
                <div class="flex gap-1.5">
                  <span class="w-3 h-3 rounded-full bg-red-400"></span>
                  <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
                  <span class="w-3 h-3 rounded-full bg-green-400"></span>
                </div>
                <span class="mono text-xs text-slate-400 ml-2">sentinel@enee:~</span>
              </div>
              <div class="mono text-xs md:text-sm p-5 md:p-6 space-y-2 leading-relaxed">
                <p class="text-slate-400">$ sentinel --init</p>
                <p class="text-[#0066CC]">▸ Agente listo. ¿Qué analizamos?</p>
                <p class="text-slate-100"><span class="text-[#FFB800]">&gt;</span> analizar zona norte sector 5</p>
                <p class="text-slate-300">🤖 invocando tool MCP → <span class="text-[#FFB800]">sentinel.query_meters</span>(zona=<span class="text-green-300">"N5"</span>)</p>
                <p class="text-slate-300">🤖 recuperando histórico vía RAG (2023–2026)...</p>
                <p class="text-slate-300">🤖 inferencia DL: autoencoder + gradient boosting</p>
                <p class="text-slate-300">🤖 <span class="text-[#FFB800] font-semibold">47 medidores sospechosos</span>. Top 20 por probabilidad...</p>
                <p class="text-slate-100"><span class="text-[#FFB800]">&gt;</span> generar ODS para los 20 primeros</p>
                <p class="text-slate-300">🤖 tool MCP → <span class="text-[#FFB800]">soe.create_ods</span>(batch=<span class="text-green-300">20</span>)</p>
                <p class="text-green-400">🤖 <span class="font-semibold">20 ODS creadas en SOE</span> <i class="fa-solid fa-check"></i></p>
                <p class="text-slate-100"><span class="text-[#FFB800]">&gt;</span><span class="cursor"></span></p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ACTO 3 — LA ASIGNACIÓN -->
      <section id="sec-3" data-reveal class="min-h-screen flex items-center px-6 py-24 bg-[#1A1A2E] text-white relative overflow-hidden">
        <div class="absolute inset-0 pointer-events-none">
          <div class="absolute top-1/3 right-0 h-80 w-80 rounded-full bg-[#0066CC]/10 blur-3xl"></div>
        </div>

        <div class="relative max-w-6xl mx-auto w-full grid lg:grid-cols-2 gap-16 items-center">
          <div data-reveal data-delay="1" class="order-2 lg:order-1">
            <!-- CLI terminal with assignment -->
