---
import PageLayout from '../layouts/PageLayout.astro';
import ServiceLanding from '../components/templates/ServiceLanding.astro';
import { agenticAutomationLanding } from '../data/serviceLandings';
import {
  buildBreadcrumbSchema,
  buildFAQSchema,
  buildServiceSchema
} from '../data/site';

const sectionNavItems = [
  { id: 'inicio', label: 'Inicio' },
  { id: 'problema', label: 'El problema' },
  { id: 'consecuencias', label: 'Consecuencias' },
  { id: 'oferta', label: 'La solución' },
  { id: 'antes-despues', label: 'Resultados' },
  { id: 'casos-aplicaciones', label: 'Por rubro' },
  { id: 'para-quien', label: '¿Es para vos?' },
  { id: 'como-funciona', label: 'Cómo trabajo' },
  { id: 'stack', label: 'Tecnología' },
  { id: 'prueba', label: 'Confianza' },
  { id: 'faq', label: 'FAQ' },
  { id: 'contacto', label: 'Contacto' }
];
---

<PageLayout
  title={agenticAutomationLanding.seoTitle}
  description={agenticAutomationLanding.seoDescription}
  path={agenticAutomationLanding.path}
  image={agenticAutomationLanding.seoImage}
  bodyVariant="mixed"
  showSectionNav={true}
  sectionNavItems={sectionNavItems}
  schemas={[
    buildServiceSchema({
      name: agenticAutomationLanding.title,
      description: agenticAutomationLanding.seoDescription,
      path: agenticAutomationLanding.path
    }),
    buildBreadcrumbSchema([
      { name: 'Inicio', path: '/' },
      { name: 'Automatización con IA Agéntica', path: agenticAutomationLanding.path }
    ]),
    buildFAQSchema(agenticAutomationLanding.faqs)
  ]}
>
  <ServiceLanding config={agenticAutomationLanding} />
</PageLayout>
